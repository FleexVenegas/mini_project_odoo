<odoo>

    <record id="view_stock_inventory_rotation" model="ir.ui.view">
        <field name="name">stock.inventory.rotation.inherit</field>
        <field name="model">product.product.stock.tree</field>
        <field name="inherit_id" ref="stock.view_product_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//tree" position="inside">
                <field name="last_sale_date"/>
            </xpath>
        </field>
    </record>



</odoo>
