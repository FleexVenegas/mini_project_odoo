<odoo>
    <record id="view_stock_quant_tree_inherit_custom" model="ir.ui.view">
        <field name="name">stock.quant.tree.inherit.custom</field>
        <field name="model">stock.quant</field>
        <field name="inherit_id" ref="stock.view_stock_quant_tree_inventory_editable"/>
        <field name="arch" type="xml">
            <!-- Inyecta la columna después del campo 'product_id' -->
            <xpath expr="//field[@name='product_id']" position="after">
                <field name="is_sold" optional="show"/>
                <field name="last_sale_date" optional="hide"/>
                <field name="months_without_sale" optional="hide"/>
                <field name="rotation_status" optional="hide"/>
            </xpath>
        </field>
    </record>
</odoo>