<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- Vista del Wizard -->
    <record id="view_pricelist_ponderada_set_price_wizard_form" model="ir.ui.view">
        <field name="name">pricelist.ponderada.set.price.wizard.form</field>
        <field name="model">pricelist.ponderada.set.price.wizard</field>
        <field name="arch" type="xml">
            <form string="Aplicar Precio Igualitario" version="7.0">
                <group>
                    <field name="price"/>
                </group>
                <footer>
                    <button name="apply_equal_price" type="object" string="Aplicar" class="btn-primary"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Acción para lanzar el Wizard -->
    <record id="action_pricelist_ponderada_set_price_wizard" model="ir.actions.act_window">
        <field name="name">Aplicar Precio Igualitario</field>
        <field name="res_model">pricelist.ponderada.set.price.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_pricelist_ponderada_set_price_wizard_form"/>
        <field name="target">new</field>
        <field name="context">{}</field>
    </record>

    <!-- Acción del servidor (botón de engrane) -->
    <record id="action_pricelist_ponderada_set_price_server" model="ir.actions.server">
        <field name="name">Aplicar Precio Igualitario</field>
        <field name="model_id" ref="model_pricelist_ponderada"/>
        <field name="binding_model_id" ref="model_pricelist_ponderada"/>
        <field name="state">code</field>
        <field name="binding_type">action</field>
        <field name="code">
action = {
    'type': 'ir.actions.act_window',
    'res_model': 'pricelist.ponderada.set.price.wizard',
    'view_mode': 'form',
    'target': 'new',
    'context': {'active_ids': records.ids},
}
        </field>
    </record>

</odoo>
