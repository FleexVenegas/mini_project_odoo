<odoo>
  <record id="view_purchase_order_sku_cost_search_form" model="ir.ui.view">
    <field name="name">purchase.order.sku.cost.search.form</field>
    <field name="model">purchase.order.sku.cost.search</field>
    <field name="arch" type="xml">
      <form string="Buscar SKUs y Costos por Órdenes de Compra" create="false" edit="false">
        <sheet>
          <group>
            <field name="order_ids" widget="many2many_tags" options="{'no_create': True}" />
          
          

          
                        <separator string="Buscador multiple" colspan="12"/>
                       <button name="action_buscar" type="object" string="Buscar" class="btn-primary" />
                        <button name="export_to_excel" string="Exportar a Excel" type="object" class="btn-primary"/>

          </group>
          <footer>
            <button string="Buscar" type="object" name="action_buscar" class="btn-primary"/>
          </footer>
          <field name="result_line_ids" nolabel="1" colspan="4" widget="one2many_list" options="{'no_create': True, 'no_edit': True}">
            <tree string="Resultados" editable="false">
              <field name="order_id"/>
              <field name="product_id"/>
              <field name="sku"/>
              <field name="cost"/>
               <field name="currency"/>
            </tree>
          </field>
        </sheet>
      </form>
    </field>
  </record>

  <record id="action_purchase_order_sku_cost_search" model="ir.actions.act_window">
    <field name="name">Buscar SKUs y Costos de Ordenes</field>
    <field name="res_model">purchase.order.sku.cost.search</field>
    <field name="view_mode">form</field>
    <field name="target">current</field>
  </record>

  <menuitem id="menu_purchase_order_sku_cost_search"
            name="Buscar SKUs y Costos"
            parent="menu_global_config_root"
            action="action_purchase_order_sku_cost_search"
            sequence="25"/>
</odoo>
