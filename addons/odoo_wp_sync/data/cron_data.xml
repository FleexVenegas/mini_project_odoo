<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
        Single shared cron for automatic synchronization with WooCommerce.

        How it works:
        - Runs every 1 minute (minimum resolution to respect per-instance intervals).
        - The _run_scheduled_sync() method iterates instances with auto_sync=True
          and only triggers sync if the sync_interval of each instance has expired.
        - Each tick cost is minimal: if no instances are pending, it finishes in milliseconds.
        - Enabling/disabling is controlled from the instance (auto_sync toggle),
          not by modifying this record.
    -->
    <record id="ir_cron_woo_auto_sync" model="ir.cron">
        <field name="name">WooCommerce: Auto Sync Instances</field>
        <field name="model_id" ref="model_woo_instance"/>
        <field name="state">code</field>
        <field name="code">model._run_scheduled_sync()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">minutes</field>
        <field name="numbercall">-1</field>
        <field name="active">True</field>
        <field name="priority">10</field>
    </record>
</odoo>
