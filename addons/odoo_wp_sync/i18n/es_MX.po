#. module: odoo_wp_sync
#: model_terms:ir.ui.view,arch_db:odoo_wp_sync.view_woo_publish_wizard_form
msgid ""
"<i class=\"fa fa-info-circle me-1\"/>\n"
"                        If this product already exists in the selected instance,\n"
"                        it will be updated instead of creating a new one.<br/>\n"
"                        The price will be taken from the <strong>pricelist configured in the instance</strong>\n"
"                        (Sales tab). If no pricelist is configured, the product list price is used.\n"
"                        You can override the price manually in the field above."
msgstr ""
"<i class=\"fa fa-info-circle me-1\"/>\n"
"                        Si este producto ya existe en la instancia seleccionada,\n"
"                        se actualizará en lugar de crear uno nuevo.<br/>\n"
"                        El precio se tomará de la <strong>lista de precios configurada en la instancia</strong>\n"
"                        (pestaña Ventas). Si no hay lista de precios configurada, se usa el precio de lista del producto.\n"
"                        Puede sobreescribir el precio manualmente en el campo de arriba."

