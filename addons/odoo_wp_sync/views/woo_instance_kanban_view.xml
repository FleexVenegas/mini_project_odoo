<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Kanban View -->
    <record id="view_woo_instance_kanban" model="ir.ui.view">
        <field name="name">woo.instance.kanban</field>
        <field name="model">woo.instance</field>
        <field name="arch" type="xml">
            <kanban sample="1" class="woo_instance_kanban">
                <field name="id"/>
                <field name="name"/>
                <field name="wp_url"/>
                <field name="state"/>
                <field name="order_count"/>
                <field name="woo_product_count"/>
                <field name="color"/>
                <field name="active"/>
                <templates>
                    <t t-name="kanban-box">
                        <div t-attf-class="oe_kanban_card woo_instance_card {{record.active.raw_value == false and 'woo_instance_card--archived' or ''}}">

                            <!-- ⋮ Dropdown menu (top-right) -->
                            <div class="o_dropdown_kanban dropdown" t-if="record.state.raw_value == 'connected'">
                                <a role="button" class="dropdown-toggle o-no-caret btn" data-bs-toggle="dropdown" href="#" aria-label="Dropdown menu" title="Opciones">
                                    <span class="fa fa-ellipsis-v"/>
                                </a>
                                <div class="dropdown-menu" data-bs-strategy="fixed" role="menu">

                                    <a role="menuitem" type="object" name="action_view_woo_products" class="dropdown-item">
                                        <i class="fa fa-cube me-2"/>
Productos WC
                                    </a>
                                    <a role="menuitem" type="object" name="action_sync_orders" class="dropdown-item">
                                        <i class="fa fa-refresh me-2"/>
Sincronizar órdenes
                                    </a>
                                    <a role="menuitem" type="object" name="action_sync_products" class="dropdown-item">
                                        <i class="fa fa-download me-2"/>
Sincronizar productos
                                    </a>
                                    <div class="dropdown-divider"/>
                                    <a role="menuitem" type="object" name="action_test_connection" class="dropdown-item">
                                        <i class="fa fa-plug me-2"/>
Reconectar
                                    </a>
                                    <a role="menuitem" type="edit" class="dropdown-item" groups="base.group_no_one">
                                        <i class="fa fa-cog me-2"/>
                                        Configuración
                                    </a>
                                </div>
                            </div>

                            <!-- Main clickable area → orders -->
                            <a type="object" name="action_open_instance" class="text-decoration-none d-block">

                                <div class="woo_card_body">
                                    <!-- Status badge -->
                                    <div class="woo_card_header_row">
                                        <div class="woo_card_icon" t-attf-style="background: {{record.color.raw_value or '#6f42c1'}}18; color: {{record.color.raw_value or '#6f42c1'}};">
                                            <i class="fa fa-shopping-bag" title="Instancia WooCommerce"/>
                                        </div>
                                        <span t-attf-class="badge {{record.state.raw_value == 'connected' and 'text-bg-success' or (record.state.raw_value == 'error' and 'text-bg-danger' or 'text-bg-secondary')}} woo_state_badge">
                                            <t t-esc="record.state.value"/>
                                        </span>
                                    </div>

                                    <!-- Name & URL -->
                                    <div class="woo_card_info">
                                        <div class="woo_card_name">
                                            <t t-esc="record.name.value"/>
                                        </div>
                                        <div class="woo_card_url text-muted">
                                            <i class="fa fa-globe me-1"/>
                                            <t t-esc="record.wp_url.value"/>
                                        </div>
                                    </div>

                                    <!-- Stats -->
                                    <div class="woo_card_stats">
                                        <div class="woo_stat_item">
                                            <span class="woo_stat_value">
                                                <t t-esc="record.order_count.value"/>
                                            </span>
                                            <span class="woo_stat_label">Pedidos</span>
                                        </div>
                                        <div class="woo_stat_divider"/>
                                        <div class="woo_stat_item">
                                            <span class="woo_stat_value">
                                                <t t-esc="record.woo_product_count.value"/>
                                            </span>
                                            <span class="woo_stat_label">Productos</span>
                                        </div>
                                    </div>
                                </div>

                            </a>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

</odoo>
