<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Tree / List View -->
    <record id="view_woo_instance_tree" model="ir.ui.view">
        <field name="name">woo.instance.tree</field>
        <field name="model">woo.instance</field>
        <field name="arch" type="xml">
            <tree string="WooCommerce Instances" decoration-muted="not active" open_form_view="False">
                <field name="sequence" widget="handle"/>
                <field name="name" string="Instance"/>
                <field name="wp_url" string="URL"/>
                <field name="state" widget="badge" decoration-success="state=='connected'" decoration-warning="state=='draft'" decoration-danger="state=='error'"/>
                <field name="order_count"/>
                <field name="company_id" groups="base.group_multi_company" optional="hide"/>
                <field name="active" column_invisible="1"/>
                <button name="action_open_instance" type="object" string="Open" class="btn-primary" icon="fa-external-link"/>
                <button name="action_sync_orders" type="object" string="Sync Orders" class="btn-secondary" icon="fa-refresh" invisible="state != 'connected'"/>
                <button name="%(action_woo_instance)d" type="action" context="{'form_view_ref': 'odoo_wp_sync.view_woo_instance_form'}" string="Settings" class="btn-link" icon="fa-cog" groups="base.group_no_one"/>
            </tree>
        </field>
    </record>

</odoo>
