<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ── Action ─────────────────────────────────────────────────────────── -->
    <record id="action_woo_product" model="ir.actions.act_window">
        <field name="name">WooCommerce Products</field>
        <field name="res_model">woo.product</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No products imported yet
            </p>
            <p>
                Go to a WooCommerce instance and click
                <strong>Sync Products</strong> to import them.
            </p>
        </field>
    </record>

    <!-- ── Tree ───────────────────────────────────────────────────────────── -->
    <record id="view_woo_product_tree" model="ir.ui.view">
        <field name="name">woo.product.tree</field>
        <field name="model">woo.product</field>
        <field name="arch" type="xml">
            <tree string="WooCommerce Products" default_order="instance_id, woo_id" decoration-muted="link_state == 'unlinked'" decoration-danger="stock_status == 'outofstock'">
                <field name="instance_id" string="Instance" optional="show"/>
                <field name="woo_sku" string="SKU" optional="show"/>
                <field name="woo_name" string="WC Product"/>
                <field name="product_tmpl_id" string="Odoo Product" optional="show"/>
                <field name="woo_status" string="Visibility" widget="badge" decoration-success="woo_status == 'publish'" decoration-warning="woo_status == 'pending'" decoration-info="woo_status == 'draft'" decoration-muted="woo_status == 'private'"/>
                <field name="stock_status" string="Stock Status" widget="badge" decoration-success="stock_status == 'instock'" decoration-warning="stock_status == 'onbackorder'" decoration-danger="stock_status == 'outofstock'"/>
                <field name="woo_price" string="Price" optional="show" widget="monetary"/>
                <field name="link_state" string="Link" widget="badge" decoration-success="link_state == 'linked'" decoration-warning="link_state == 'unlinked'"/>
                <field name="woo_pending_sync" string="Sync Pending" widget="boolean" optional="show"/>
                <field name="last_sync_date" string="Last sync" optional="hide"/>
                <!-- Campos auxiliares no visibles, requeridos por decorators -->
                <field name="woo_id" optional="hide"/>
            </tree>
        </field>
    </record>

    <!-- ── Form ───────────────────────────────────────────────────────────── -->
    <record id="view_woo_product_form" model="ir.ui.view">
        <field name="name">woo.product.form</field>
        <field name="model">woo.product</field>
        <field name="arch" type="xml">
            <form string="WooCommerce Product">
                <header>
                    <button name="action_confirm_create_in_wc" string="Create in WooCommerce" type="object" class="btn-primary" invisible="woo_id"/>
                    <button name="action_confirm_update_stock_wc" string="Sync with WooCommerce" type="object" class="btn-primary" invisible="not woo_id"/>
                    <field name="woo_status" widget="statusbar" statusbar_visible="draft,pending,publish,private" options="{'clickable': '1'}"/>
                </header>
                <sheet>

                    <!-- ── Smart buttons ──────────────────────────────────────── -->
                    <div class="oe_button_box" name="button_box">
                        <button name="action_link_manually" type="object" class="oe_stat_button" icon="fa-link" invisible="product_tmpl_id" title="Link to Odoo product">
                            <div class="o_field_widget o_stat_info">
                                <span class="o_stat_text">Link</span>
                            </div>
                        </button>
                        <button name="action_unlink" type="object" class="oe_stat_button" icon="fa-chain-broken" invisible="not product_tmpl_id" title="Unlink from Odoo">
                            <div class="o_field_widget o_stat_info">
                                <span class="o_stat_text">Unlink</span>
                            </div>
                        </button>
                    </div>

                    <!-- ── Header: Image + Name + Badges ────────────────── -->
                    <div class="d-flex align-items-start gap-4 mb-4">
                        <div class="flex-shrink-0" invisible="not woo_image_src">
                            <field name="woo_image_preview" nolabel="1"/>
                        </div>
                        <div class="oe_title flex-grow-1">
                            <h1>
                                <field name="woo_name" placeholder="Product name"/>
                            </h1>
                            <div class="d-flex flex-wrap align-items-center gap-2 mt-2">
                                <field name="link_state" widget="badge" decoration-success="link_state == 'linked'" decoration-warning="link_state == 'unlinked'"/>
                                <field name="stock_status" widget="badge" decoration-success="stock_status == 'instock'" decoration-warning="stock_status == 'onbackorder'" decoration-danger="stock_status == 'outofstock'"/>
                                <span class="text-muted fw-bold" invisible="woo_id">
                                    WC #<field name="woo_id" readonly="1" class="d-inline"/>
                                </span>
                            </div>
                        </div>
                    </div>

                    <!-- ── Section 1: Identification ─────────────────────────── -->
                    <group>
                        <group string="WooCommerce">
                            <field name="instance_id" readonly="woo_id"/>
                            <field name="woo_sku"/>
                            <field name="woo_type" readonly="woo_id"/>
                            <field name="woo_permalink" widget="url" string="View in store" readonly="1" invisible="not woo_permalink"/>
                        </group>
                        <group string="Link with Odoo">
                            <field name="product_tmpl_id" options="{'no_create': True}" domain="[('sale_ok', '=', True)]"/>
                            <field name="last_sync_date" readonly="1"/>
                        </group>
                    </group>

                    <!-- ── Section 2: Price ─────────────────────────────────── -->
                    <group string="Price">
                        <group string="Reference">
                            <field name="pricelist_id" readonly="1" string="Active pricelist"/>
                            <field name="pricelist_price" readonly="1" widget="monetary" string="Price per list"/>
                            <field name="woo_price" readonly="1" widget="monetary" string="Current WC price" invisible="not woo_id"/>
                        </group>
                        <group string="Price to publish">
                            <field name="woo_price_input" widget="monetary" string="Manual price" help="Leave at 0 to use the instance pricelist price."/>
                        </group>
                    </group>

                    <!-- ── Section 3: Stock and Image ────────────────────────── -->
                    <group>
                        <group string="Stock control">
                            <field name="instance_manage_stock" invisible="1"/>
                            <field name="stock_status" widget="radio"/>
                            <field name="stock_quantity" string="Quantity in stock" invisible="not instance_manage_stock" help="Stock quantity to send to WooCommerce. Automatically enables stock management."/>
                            <field name="woo_min_stock" string="Minimum stock" invisible="not instance_manage_stock" help="Minimum quantity before marking the product as out of stock."/>
                            <field name="woo_max_stock" string="Maximum stock" invisible="not instance_manage_stock" help="Maximum stock quantity to manage in WooCommerce."/>
                        </group>
                        <group string="Image">
                            <field name="woo_image_src" readonly="1" widget="url" string="Current image" invisible="not woo_image_src"/>
                            <field name="woo_image_url_input" string="New image URL" placeholder="https://example.com/image.jpg" help="WooCommerce will download the image from this URL. Not stored in Odoo."/>
                        </group>
                    </group>

                    <!-- ── Section 4: Categories and Brands ──────────────────── -->
                    <group>
                        <group string="WooCommerce Categories">
                            <field name="woo_category_ids" widget="many2many_tags" options="{'no_create': True}" domain="[('instance_id', '=', instance_id)]" string="Categories" help="Respects the parent/child hierarchy of WooCommerce."/>
                        </group>
                        <group string="WooCommerce Brands">
                            <field name="woo_brand_ids" widget="many2many_tags" options="{'no_create': True}" domain="[('instance_id', '=', instance_id)]" string="Brands" help="Requires the brands plugin installed in WooCommerce."/>
                        </group>
                    </group>

                    <!-- ── Alerts ──────────────────────────────────────────── -->
                    <div class="alert alert-info mt-2" role="status" invisible="not woo_id">
                        <i class="fa fa-info-circle me-1"/>
                        Modify the values and press <strong>Sync with WooCommerce</strong> to apply the changes.
                    </div>
                    <div class="alert alert-warning mt-2" role="status" invisible="woo_id">
                        <i class="fa fa-exclamation-triangle me-1"/>
                        Complete the data and click <strong>Create in WooCommerce</strong> to publish the product.
                        The price will be taken from the <strong>instance pricelist</strong>, unless you specify a manual price.
                    </div>

                </sheet>
            </form>
        </field>
    </record>

    <!-- ── Search ─────────────────────────────────────────────────────────── -->
    <record id="view_woo_product_search" model="ir.ui.view">
        <field name="name">woo.product.search</field>
        <field name="model">woo.product</field>
        <field name="arch" type="xml">
            <search string="Search WooCommerce Products">
                <!-- Quick search -->
                <field name="woo_name" string="Name"/>
                <field name="woo_sku" string="SKU"/>
                <field name="product_tmpl_id" string="Odoo Product"/>
                <field name="instance_id" string="Instance"/>

                <!-- Link filters -->
                <filter name="linked" string="Linked" domain="[('link_state','=','linked')]"/>
                <filter name="unlinked" string="Unlinked" domain="[('link_state','=','unlinked')]"/>
                <separator/>
                <!-- Status filters -->
                <filter name="published" string="Published" domain="[('woo_status','=','publish')]"/>
                <filter name="draft" string="Drafts" domain="[('woo_status','=','draft')]"/>
                <separator/>
                <!-- Pending sync filter -->
                <filter name="pending_sync" string="Pending sync to WooCommerce" domain="[('woo_pending_sync','=',True)]"/>
                <separator/>
                <!-- Stock filters -->
                <filter name="instock" string="In stock" domain="[('stock_status','=','instock')]"/>
                <filter name="outofstock" string="Out of stock" domain="[('stock_status','=','outofstock')]"/>
                <filter name="onbackorder" string="On backorder" domain="[('stock_status','=','onbackorder')]"/>

                <group expand="0" string="Group By">
                    <filter name="group_instance" string="Instance" context="{'group_by': 'instance_id'}"/>
                    <filter name="group_link" string="Link" context="{'group_by': 'link_state'}"/>
                    <filter name="group_status" string="Status" context="{'group_by': 'woo_status'}"/>
                    <filter name="group_stock" string="Stock status" context="{'group_by': 'stock_status'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ── Server action: Sync selected records to WooCommerce ────────────── -->
    <record id="action_woo_product_push_to_wc" model="ir.actions.server">
        <field name="name"> ↻ Sync to wc</field>
        <field name="model_id" ref="odoo_wp_sync.model_woo_product"/>
        <field name="binding_model_id" ref="odoo_wp_sync.model_woo_product"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">records.action_push_pending_to_wc()</field>
    </record>

</odoo>
