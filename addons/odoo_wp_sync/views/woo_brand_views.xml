<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ── Action ─────────────────────────────────────────────────────────── -->
    <record id="action_woo_brand" model="ir.actions.act_window">
        <field name="name">WooCommerce Brands</field>
        <field name="res_model">woo.brand</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No brands registered yet
            </p>
            <p>
                Brands are created automatically when syncing products,
                or you can create them manually to assign them to your products.
                Requires a brands plugin installed in WooCommerce.
            </p>
        </field>
    </record>

    <!-- ── Tree ───────────────────────────────────────────────────────────── -->
    <record id="view_woo_brand_tree" model="ir.ui.view">
        <field name="name">woo.brand.tree</field>
        <field name="model">woo.brand</field>
        <field name="arch" type="xml">
            <tree string="WooCommerce Brands" decoration-muted="not woo_id" decoration-warning="pending_sync">
                <field name="instance_id" string="Instance" optional="show"/>
                <field name="name" string="Brand"/>
                <field name="slug" string="Slug" optional="show"/>
                <field name="woo_id" string="WC ID" optional="show"/>
                <field name="pending_sync" string="Pending" optional="show"/>
                <field name="last_sync_date" string="Last Sync" optional="show"/>
                <!-- <button name="action_sync_to_woocommerce" type="object" string="Sync" icon="fa-refresh" class="btn-sm btn-link"/> -->
            </tree>
        </field>
    </record>

    <!-- ── Form ───────────────────────────────────────────────────────────── -->
    <record id="view_woo_brand_form" model="ir.ui.view">
        <field name="name">woo.brand.form</field>
        <field name="model">woo.brand</field>
        <field name="arch" type="xml">
            <form string="WooCommerce Brand">
                <header>
                    <button name="action_sync_to_woocommerce" type="object" string="Sync to WooCommerce" class="btn-primary" invisible="not instance_id"/>
                    <span class="o_form_label text-warning fw-bold ms-2" invisible="not pending_sync">
                        ⚠ Pending sync
                    </span>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Brand name"/>
                        </h1>
                    </div>
                    <group>
                        <group string="WooCommerce">
                            <field name="instance_id"/>
                            <field name="woo_id" string="WooCommerce ID" readonly="1"/>
                            <field name="slug" string="Slug"/>
                        </group>
                        <group string="Sync Info" invisible="not last_sync_date">
                            <field name="last_sync_date" readonly="1"/>
                            <field name="pending_sync" readonly="1"/>
                        </group>
                    </group>
                    <group >
                        <field name="description"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ── Search ─────────────────────────────────────────────────────────── -->
    <record id="view_woo_brand_search" model="ir.ui.view">
        <field name="name">woo.brand.search</field>
        <field name="model">woo.brand</field>
        <field name="arch" type="xml">
            <search string="Search Brands">
                <field name="name" string="Name"/>
                <field name="slug" string="Slug"/>
                <field name="instance_id" string="Instance"/>
                <separator/>
                <filter name="with_woo_id" string="Synced" domain="[('woo_id', '!=', 0)]"/>
                <filter name="pending_sync" string="Pending Sync" domain="[('pending_sync', '=', True)]"/>
                <group expand="0" string="Group By">
                    <filter name="group_instance" string="Instance" context="{'group_by': 'instance_id'}"/>
                </group>
            </search>
        </field>
    </record>


</odoo>
