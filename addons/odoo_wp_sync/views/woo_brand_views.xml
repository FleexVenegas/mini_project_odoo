<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ── Action ─────────────────────────────────────────────────────────── -->
    <record id="action_woo_brand" model="ir.actions.act_window">
        <field name="name">Marcas WooCommerce</field>
        <field name="res_model">woo.brand</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No hay marcas registradas todavía
            </p>
            <p>
                Las marcas se crean automáticamente al sincronizar productos,
                o puedes crearlas manualmente para asignarlas a tus productos.
                Requiere un plugin de marcas instalado en WooCommerce.
            </p>
        </field>
    </record>

    <!-- ── Tree ───────────────────────────────────────────────────────────── -->
    <record id="view_woo_brand_tree" model="ir.ui.view">
        <field name="name">woo.brand.tree</field>
        <field name="model">woo.brand</field>
        <field name="arch" type="xml">
            <tree string="Marcas WooCommerce" decoration-muted="not woo_id">
                <field name="instance_id" string="Instancia" optional="show"/>
                <field name="name" string="Marca"/>
                <field name="slug" string="Slug" optional="show"/>
                <field name="woo_id" string="WC ID" optional="show"/>
            </tree>
        </field>
    </record>

    <!-- ── Form ───────────────────────────────────────────────────────────── -->
    <record id="view_woo_brand_form" model="ir.ui.view">
        <field name="name">woo.brand.form</field>
        <field name="model">woo.brand</field>
        <field name="arch" type="xml">
            <form string="Marca WooCommerce">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Nombre de la marca"/>
                        </h1>
                    </div>
                    <group>
                        <group string="WooCommerce">
                            <field name="instance_id"/>
                            <field name="woo_id" string="ID en WooCommerce" readonly="1"/>
                            <field name="slug" string="Slug"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ── Search ─────────────────────────────────────────────────────────── -->
    <record id="view_woo_brand_search" model="ir.ui.view">
        <field name="name">woo.brand.search</field>
        <field name="model">woo.brand</field>
        <field name="arch" type="xml">
            <search string="Buscar marcas">
                <field name="name" string="Nombre"/>
                <field name="slug" string="Slug"/>
                <field name="instance_id" string="Instancia"/>
                <separator/>
                <filter name="with_woo_id" string="Sincronizadas" domain="[('woo_id', '!=', 0)]"/>
                <group expand="0" string="Agrupar por">
                    <filter name="group_instance" string="Instancia" context="{'group_by': 'instance_id'}"/>
                </group>
            </search>
        </field>
    </record>


</odoo>
