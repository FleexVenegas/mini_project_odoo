<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="res_config_settings_view_form_wp_sync" model="ir.ui.view">
            <field name="name">res.config.settings.view.form.inherit.wp.sync</field>
            <field name="model">res.config.settings</field>
            <field name="inherit_id" ref="base.res_config_settings_view_form"/>
            <field name="arch" type="xml">
                <xpath expr="//form" position="inside">
                    <app string="WordPress Sync" name="odoo_wp_sync" logo="/odoo_wp_sync/static/description/icon.png" groups="base.group_system">

                        <block title="Sitio WordPress">
                            <setting string="URL del sitio" help="Dirección base de tu sitio WordPress, sin barra diagonal al final. Ejemplo: https://tusitio.com">
                                <field name="wp_url" placeholder="https://tusitio.com"/>
                            </setting>
                        </block>

                        <block title="Credenciales API WooCommerce">
                            <setting string="Consumer Key" help="Clave pública generada en WooCommerce → Ajustes → Avanzado → API REST → Agregar clave.">
                                <field name="wp_ck" placeholder="ck_xxxxxxxxxxxxxxxxxxxxxxxx"/>
                            </setting>
                            <setting string="Consumer Secret" help="Clave secreta generada junto con el Consumer Key. Trátala como una contraseña.">
                                <field name="wp_cs" password="True" placeholder="cs_xxxxxxxxxxxxxxxxxxxxxxxx"/>
                            </setting>
                        </block>

                    </app>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
