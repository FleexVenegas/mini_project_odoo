<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="res_config_settings_view_form_wp_sync" model="ir.ui.view">
            <field name="name">res.config.settings.view.form.inherit.wp.sync</field>
            <field name="model">res.config.settings</field>
            <field name="inherit_id" ref="base.res_config_settings_view_form"/>
            <field name="arch" type="xml">
                <xpath expr="//form" position="inside">
                    <app string="WordPress Sync" name="odoo_wp_sync" logo="/odoo_wp_sync/static/description/icon.png" groups="base.group_system">

                        <block title="Sitio WordPress">
                            <setting string="URL del sitio" help="Dirección base de tu sitio WordPress, sin barra diagonal al final. Ejemplo: https://tusitio.com">
                                <field name="wp_url" placeholder="https://tusitio.com"/>
                            </setting>
                        </block>

                        <block title="Credenciales API WooCommerce">
                            <setting string="Consumer Key" help="Clave pública generada en WooCommerce → Ajustes → Avanzado → API REST → Agregar clave.">
                                <field name="wp_ck" placeholder="ck_xxxxxxxxxxxxxxxxxxxxxxxx"/>
                            </setting>
                            <setting string="Consumer Secret" help="Clave secreta generada junto con el Consumer Key. Trátala como una contraseña.">
                                <field name="wp_cs" password="True" placeholder="cs_xxxxxxxxxxxxxxxxxxxxxxxx"/>
                            </setting>
                        </block>

                        <block title="Acciones">
                            <setting string="Probar conexión" help="Verifica que las credenciales sean correctas y que puedas conectarte a WooCommerce.">
                                <button name="action_test_connection" type="object" string="Probar Conexión" class="btn-secondary" icon="fa-plug"/>
                            </setting>
                            <!-- <setting string="Sincronizar ahora" help="Sincroniza productos/órdenes desde WooCommerce a Odoo.">
                                <button name="%(action_server_sync_woocommerce)d" type="action" string="Sincronizar WooCommerce" class="btn-primary" icon="fa-refresh"/>
                            </setting> -->
                        </block>

                    </app>
                </xpath>
            </field>
        </record>
        <record id="action_wp_sync_settings" model="ir.actions.act_window">
            <field name="name">WordPress Sync Settings</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">res.config.settings</field>
            <field name="view_mode">form</field>
            <field name="target">inline</field>
            <field name="context">{'module': 'odoo_wp_sync'}</field>
        </record>

        <record id="action_wp_test_connection" model="ir.actions.server">
            <field name="name">Test Connection</field>
            <field name="model_id" ref="base.model_res_config_settings"/>
            <field name="state">code</field>
            <field name="code">
action = env['res.config.settings'].action_test_connection()
            </field>
        </record>
    </data>
</odoo>
