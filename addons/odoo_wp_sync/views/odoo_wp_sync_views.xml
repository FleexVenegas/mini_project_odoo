<odoo>

    <!-- Acción primero (evita ParseError) -->
    <record id="action_odoo_wp_sync" model="ir.actions.act_window">
        <field name="name">OdooWpSync</field>
        <field name="res_model">odoo.wp.sync</field>
        <field name="view_mode">tree,form</field>
    </record>

    <!-- Vista Tree -->
    <record id="view_odoo_wp_sync_tree" model="ir.ui.view">
        <field name="name">odoo_wp_sync.tree</field>
        <field name="model">odoo.wp.sync</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
            </tree>
        </field>
    </record>

    <!-- Menú raíz -->
    <menuitem id="odoo_wp_sync_menu_root" name="OdooWpSync"/>

    <!-- Submenú -->
    <menuitem 
        id="odoo_wp_sync_menu_modelo" 
        name="Registros"
        parent="odoo_wp_sync_menu_root"
        action="action_odoo_wp_sync"
    />

</odoo>
