<odoo>

    <!-- Vista Tree -->
    <record id="view_odoo_wp_sync_tree" model="ir.ui.view">
        <field name="name">odoo_wp_sync.tree</field>
        <field name="model">odoo.wp.sync</field>
        <field name="arch" type="xml">
            <tree string="WooCommerce Orders" default_order="date_created desc" multi_edit="1">
                <header>
                    <button name="action_open_create_sale_order_wizard" type="object" string="Crear Pedidos" class="btn-secondary" icon="fa-plus"/>
                </header>
                <field name="name" string="Pedido"/>
                <field name="total" string="Total" widget="monetary" options="{'currency_field': 'currency'}"/>
                <field name="currency" string="Moneda"/>
                <field name="date_created" string="Fecha"/>
                <field name="status" string="Estado" widget="badge" decoration-info="status in ('pending', 'on-hold')" decoration-success="status == 'completed'" decoration-warning="status == 'processing'" decoration-danger="status in ('cancelled', 'refunded', 'failed')"/>
                <field name="sale_order_id" string="Pedido Odoo"/>
            </tree>
        </field>
    </record>

    <!-- Vista Form -->
    <record id="view_odoo_wp_sync_form" model="ir.ui.view">
        <field name="name">odoo_wp_sync.form</field>
        <field name="model">odoo.wp.sync</field>
        <field name="arch" type="xml">
            <form string="WooCommerce Order">
                <header>
                    <field name="status" widget="statusbar" options="{'clickable': '0'}" statusbar_visible="pending,processing,completed"/>
                </header>

                <sheet>
                    <!-- Title Section with Total Amount -->
                    <div class="oe_title mb-3">
                        <div class="row">
                            <div class="col-8">
                                <label for="order_number" class="oe_edit_only"/>
                                <h1 class="d-flex align-items-center">
                                    <span class="me-2">Pedido</span>
                                    <field name="order_number" readonly="1" class="text-break" placeholder="Número de pedido"/>
                                </h1>
                            </div>
                            <div class="col-4 text-end">
                                <div class="d-flex flex-column align-items-end">
                                    <span class="text-muted" style="font-size: 14px;">Total del Pedido</span>
                                    <h1 class="mb-0" style="font-weight: bold; color: #000;">
                                        <field name="total" widget="monetary" options="{'currency_field': 'currency'}" readonly="1" nolabel="1"/>
                                        <field name="currency" invisible="1"/>
                                    </h1>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Summary Card -->
                    <div class="o_group">
                        <group>
                            <group string="Información del Cliente" class="mb-4">
                                <field name="customer_name" string="Nombre" readonly="1"/>
                                <field name="customer_email" string="Email" widget="email" readonly="1"/>
                                <field name="customer_phone" string="Teléfono" widget="phone" readonly="1"/>
                            </group>
                            <group string="Detalles del Pedido" class="mb-4">
                                <field name="wc_order_id" string="ID WooCommerce" readonly="1"/>
                                <field name="date_created" string="Fecha de Creación" readonly="1"/>
                                <field name="payment_method" string="Método de Pago" readonly="1"/>
                                <field name="created_via" string="Origen" readonly="1"/>
                            </group>
                        </group>
                    </div>

                    <notebook>
                        <!-- Order Items -->
                        <page string="Productos" name="items">

                            <field name="items_info" nolabel="1" readonly="1" placeholder="La información de los productos aparecerá aquí..." options="{'resizable': False}"/>

                        </page>

                        <!-- Shipping Information -->
                        <page string="Dirección de Envío" name="shipping">

                            <field name="shipping_address" nolabel="1" readonly="1" placeholder="La dirección de envío aparecerá aquí..." options="{'resizable': False}"/>

                        </page>

                        <!-- Technical Data -->
                        <page string="Datos Técnicos" name="technical_data" groups="base.group_no_one">
                            <group>
                                <field name="synced_date" string="Última Sincronización" readonly="1"/>
                            </group>
                            <separator string="JSON Completo de WooCommerce"/>
                            <field name="raw_data" nolabel="1" readonly="1" widget="ace" options="{'language': 'json'}" placeholder="Datos en formato JSON..."/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Vista de búsqueda (filtros y agrupación) -->
    <record id="view_odoo_wp_sync_search" model="ir.ui.view">
        <field name="name">odoo_wp_sync.search</field>
        <field name="model">odoo.wp.sync</field>
        <field name="arch" type="xml">
            <search string="Search Orders">
                <field name="name"/>
                <field name="order_number"/>
                <field name="customer_name"/>
                <field name="customer_email"/>

                <filter string="Pending" name="filter_pending" domain="[('status', 'in', ['pending', 'on-hold'])]"/>
                <filter string="Processing" name="filter_processing" domain="[('status', '=', 'processing')]"/>
                <filter string="Completed" name="filter_completed" domain="[('status', '=', 'completed')]"/>

                <separator/>
                <filter string="Today" name="filter_today" domain="[('date_created', '&gt;=', context_today().strftime('%Y-%m-%d 00:00:00'))]"/>
                <filter string="This Week" name="filter_week" domain="[('date_created', '&gt;=', (context_today() - relativedelta(weeks=1)).strftime('%Y-%m-%d 00:00:00'))]"/>

                <group expand="0" string="Group By">
                    <filter string="Status" name="group_status" context="{'group_by': 'status'}"/>
                    <filter string="Date" name="group_date" context="{'group_by': 'date_created:day'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Acción -->
    <record id="action_odoo_wp_sync" model="ir.actions.act_window">
        <field name="name">WooCommerce Orders</field>
        <field name="res_model">odoo.wp.sync</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No orders synchronized yet
            </p>
            <p>
                Click on "Sincronizar Ahora" in the menu to import orders from WooCommerce.
            </p>
        </field>
    </record>


    <!-- Acción para abrir el wizard de confirmación de sincronización -->
    <record id="action_server_woo_sync_wizard" model="ir.actions.server">
        <field name="name">Sincronizar WooCommerce</field>
        <field name="model_id" ref="model_odoo_wp_sync"/>
        <field name="state">code</field>
        <field name="code">
action = model.action_open_sync_wizard()
        </field>
    </record>

    <!-- Acción de servidor para sincronización desde menú -->
    <record id="action_server_sync_woocommerce" model="ir.actions.server">
        <field name="name">Sincronizar con WooCommerce</field>
        <field name="model_id" ref="model_odoo_wp_sync"/>
        <field name="state">code</field>
        <field name="code">
action = model.action_open_sync_wizard()
        </field>
    </record>

</odoo>