<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Form View -->
    <record id="view_woo_instance_form" model="ir.ui.view">
        <field name="name">woo.instance.form</field>
        <field name="model">woo.instance</field>
        <field name="arch" type="xml">
            <form string="WooCommerce Instance">
                <header>
                    <button name="action_test_connection" string="Test Connection" type="object" class="btn-primary" invisible="state == 'connected'"/>
                    <button name="action_test_connection" string="Reconnect" type="object" class="btn-secondary" invisible="state != 'connected'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,connected"/>
                </header>
                <sheet>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="active"/>
                    <field name="active" invisible="1"/>

                    <!-- Smart Buttons -->
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_orders" type="object" class="oe_stat_button" icon="fa-shopping-cart" invisible="state != 'connected'">
                            <field name="order_count" widget="statinfo" string="Orders"/>
                        </button>
                        <button name="action_sync_orders" type="object" class="oe_stat_button" icon="fa-refresh" invisible="state != 'connected'">
                            <div class="o_field_widget o_stat_info">
                                <span class="o_stat_text">Sync Orders</span>
                            </div>
                        </button>
                        <button name="action_view_woo_products" type="object" class="oe_stat_button" icon="fa-cube" invisible="state != 'connected'">
                            <field name="woo_product_count" widget="statinfo" string="WC Products"/>
                        </button>
                        <button name="action_sync_products" type="object" class="oe_stat_button" icon="fa-refresh" invisible="state != 'connected'">
                            <div class="o_field_widget o_stat_info">
                                <span class="o_stat_text">Sync Products</span>
                            </div>
                        </button>
                        <button name="action_view_coupons" type="object" class="oe_stat_button" icon="fa-tag" invisible="state != 'connected'">
                            <field name="coupon_count" widget="statinfo" string="Coupons"/>
                        </button>

                        <button name="action_sync_coupons" type="object" class="oe_stat_button" icon="fa-refresh" invisible="state != 'connected'">
                            <div class="o_field_widget o_stat_info">
                                <span class="o_stat_text">Sync Coupons</span>
                            </div>
                        </button>
                    </div>

                    <!-- Title -->
                    <div class="oe_title mb-3">
                        <h1 class="d-flex align-items-center gap-2">
                            <field name="color" widget="color_picker"/>
                            <field name="name" placeholder="Instance name" class="o_text_overflow"/>
                        </h1>
                    </div>

                    <!-- Connection fields -->
                    <group>
                        <group string="WooCommerce Credentials">
                            <field name="wp_url" placeholder="https://mystore.com" widget="url" readonly="state == 'connected'"/>
                            <field name="consumer_key" password="True" placeholder="ck_xxxxxxxxxxxxx" readonly="state == 'connected'"/>
                            <field name="consumer_secret" password="True" placeholder="cs_xxxxxxxxxxxxx" readonly="state == 'connected'"/>
                        </group>
                        <group string="General">
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>

                    <!-- Connection Status Alert -->
                    <div class="alert" role="alert" invisible="not last_connection_test" t-attf-class="alert-{{state == 'connected' and 'success' or (state == 'error' and 'danger' or 'info')}}">
                        <div class="d-flex align-items-center gap-2">
                            <i t-attf-class="fa fa-lg {{state == 'connected' and 'fa-check-circle' or (state == 'error' and 'fa-times-circle' or 'fa-info-circle')}}" title="Connection status"/>
                            <div>
                                <field name="connection_message"/>
                                <div class="small text-muted mt-1">
                                    Last test: <field name="last_connection_test"/>
                                </div>
                            </div>
                        </div>
                    </div>

                    <notebook>

                        <!-- ── Getting Started ─────────────────────────── -->
                        <page string="Getting Started" name="setup_guide" invisible="state == 'connected'">
                            <div class="p-3">
                                <div class="alert alert-info" role="alert">
                                    <i class="fa fa-lightbulb-o me-2"/>
                                    Follow these steps to connect your WooCommerce store.
                                </div>
                                <div class="row g-3">
                                    <div class="col-md-6">
                                        <div class="border rounded p-3 bg-light">
                                            <h6>
                                                <span class="badge bg-primary me-2">1</span>Access WooCommerce</h6>
                                            <p class="mb-0 small">Go to: <code>WooCommerce → Settings → Advanced → REST API</code>
                                            </p>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="border rounded p-3 bg-light">
                                            <h6>
                                                <span class="badge bg-primary me-2">2</span>Generate an API Key</h6>
                                            <p class="mb-0 small">Click <strong>Add key</strong>, permissions: <code>Read/Write</code>
                                            </p>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="border rounded p-3 bg-light">
                                            <h6>
                                                <span class="badge bg-primary me-2">3</span>Copy the credentials</h6>
                                            <p class="mb-0 small">Copy the <strong>Consumer Key</strong> and <strong>Consumer Secret</strong>
                                            </p>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="border rounded p-3 bg-light">
                                            <h6>
                                                <span class="badge bg-primary me-2">4</span>Test the connection</h6>
                                            <p class="mb-0 small">Paste the credentials above and click <strong>Test Connection</strong>
                                            </p>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </page>

                        <!-- ── Synchronization ─────────────────────────── -->
                        <page string="Synchronization" name="parameters" invisible="state != 'connected'">
                            <group string="Order Settings">
                                <group>
                                    <field name="sync_order_limit" widget="integer"/>
                                    <field name="sync_from_date"/>
                                    <field name="sync_order_status"/>
                                    <field name="sync_custom_statuses" placeholder="pending,processing,completed" invisible="sync_order_status != 'custom'"/>

                                </group>
                                <group>
                                    <field name="auto_sync" widget="boolean_toggle"/>
                                    <field name="sync_interval" invisible="not auto_sync"/>
                                    <field name="next_auto_sync_date" readonly="1" invisible="not auto_sync"/>
                                </group>
                            </group>


                            <group string="Synchronization Strategy">
                                <group>
                                    <field name="incremental_enabled" widget="boolean_toggle"/>
                                    <field name="full_sync_interval_days" invisible="not incremental_enabled"/>
                                </group>
                                <group>
                                    <field name="sync_mode"/>
                                </group>
                            </group>

                            <group string="Statistics" invisible="not last_sync_date">
                                <group>
                                    <field name="last_sync_date" readonly="1"/>
                                    <field name="last_full_sync_date" readonly="1"/>
                                    <field name="total_synced_orders" readonly="1"/>
                                </group>
                                <group>
                                    <field name="last_sync_order_count" readonly="1"/>
                                    <field name="sync_error_count" readonly="1"/>
                                    <field name="sync_duration" readonly="1"/>
                                </group>
                            </group>
                        </page>

                        <!-- ── Sales ─────────────────────────────────── -->
                        <page string="Sales" name="sales" invisible="state != 'connected'">
                            <group string="Sales Team">
                                <group>
                                    <field name="seller_id" string="Salesperson"/>
                                    <field name="sale_team_id" string="Sales Team"/>
                                    <field name="client_id" string="Default Customer"/>
                                </group>
                                <group>
                                    <field name="use_sequence" string="Use Sequence" widget="boolean_toggle"/>
                                    <field name="prefix_sequence" invisible="use_sequence != False"/>
                                    <field name="sequence" invisible="use_sequence != True"/>
                                </group>
                            </group>

                            <group string="Prices and Payments">
                                <group>
                                    <field name="pricelist_id" string="Pricelist"/>
                                    <field name="payment_term_id" string="Payment Terms"/>
                                    <field name="wc_shipping" string="Include shipping cost" widget="boolean_toggle"/>
                                </group>
                                <group>
                                    <field name="taxes_included_price" string="Prices include VAT" widget="boolean_toggle"/>
                                    <field name="tax_id" string="Tax" invisible="taxes_included_price != False"/>
                                    <field name="picking_policy" string="Delivery Policy"/>
                                </group>
                            </group>

                            <!-- <group string="Data Relevance">
                                <field name="company_id" string="Company"/>
                            </group> -->

                            <group string="Behavior">
                                <group>
                                    <field name="confirm_orders" string="Manually confirm orders" widget="boolean_toggle"/>
                                </group>
                            </group>

                            <group string="Automatic Order Creation">
                                <group>
                                    <field name="auto_create_sale_order" widget="boolean_toggle"/>
                                    <field name="auto_create_sale_order_statuses" placeholder="processing,completed" invisible="not auto_create_sale_order"/>
                                </group>
                                <!-- <group invisible="not auto_create_sale_order">
                                    <div class="alert alert-info" role="alert" colspan="2">
                                        <i class="fa fa-info-circle me-1"/>
                                        On sync, a sale order will be created for each order whose status matches the configured ones.
                                        If <b>Automatically confirm orders</b> is active, the order will be confirmed directly;
                                        otherwise it will remain as a quotation.
                                    </div>
                                </group> -->
                            </group>
                        </page>

                        <!-- ── Warehouse ────────────────────────────── -->
                        <page string="Warehouse" name="warehouse" invisible="state != 'connected'">
                            <group string="Warehouse Settings">
                                <group>
                                    <field name="warehouse_id"/>
                                </group>
                                <group>
                                    <field name="update_order_status_wc" widget="boolean_toggle"/>
                                </group>
                            </group>

                            <group string="Product inventory">
                                <group>
                                    <field name="manage_stock" widget="boolean_toggle"/>
                                    <!-- <field name="update_stock" widget="boolean_toggle" invisible="not manage_stock"/> -->
                                </group>
                            </group>
                        </page>

                        <!-- ── Products ──────────────────────────────── -->
                        <page string="Products" name="wc_product" invisible="state != 'connected'">
                            <group string="Product Publishing">
                                <group>
                                    <field name="allow_create_products" widget="boolean_toggle"/>
                                    <field name="who_can_publish" widget="many2many_tags" invisible="not allow_create_products"/>
                                </group>
                                <group>
                                    <field name="include_taxes_wc_product_sync" widget="boolean_toggle" invisible="not allow_create_products"/>
                                    <field name="taxes_product" string="Taxes" invisible="not allow_create_products or not include_taxes_wc_product_sync"/>
                                </group>
                            </group>
                        </page>

                        <!-- ── Coupons ───────────────────────────────── -->
                        <page string="Coupons" name="coupons" invisible="state != 'connected'">
                            <group string="Sync Settings">
                                <group>
                                    <field name="coupon_sync_mode" widget="radio"/>
                                </group>
                                <group>
                                    <field name="coupon_last_sync_date" readonly="1" invisible="coupon_sync_mode != 'incremental'" string="Incremental since"/>
                                </group>
                            </group>

                            <group string="Import Filters">
                                <group>
                                    <field name="coupon_sync_status"/>
                                </group>
                                <group>
                                    <field name="coupon_sync_expiry"/>
                                </group>
                            </group>
                            <group string="Statistics" invisible="not coupon_last_sync_date">
                                <group>
                                    <div class="d-flex align-items-center justify-content-between mb-3">
                                        <div class="text-muted small">
                                            <i class="fa fa-clock-o me-1" title="Last sync"/>
                                         Last sync: <field name="coupon_last_sync_date" readonly="1"/>
                                        </div>
                                    </div>
                                </group>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

</odoo>
