<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_woo_bulk_publish_wizard_form" model="ir.ui.view">
        <field name="name">woo.bulk.publish.wizard.form</field>
        <field name="model">woo.bulk.publish.wizard</field>
        <field name="arch" type="xml">
            <form string="Publish to WooCommerce">
                <sheet>
                    <div class="oe_title">
                        <h1>Bulk publish to WooCommerce</h1>
                        <p class="text-muted">
                            All selected products will be published
                            to the chosen instance.
                        </p>
                    </div>

                    <group string="Settings" col="2">
                        <field name="instance_id" options="{'no_create': True}" placeholder="Select instance…"/>
                        <field name="wc_status" widget="radio"/>
                        <field name="include_taxes_product" invisible="1"/>
                        <field name="taxes_product" readonly="1" widget="many2many_tags" string="Taxes to apply" invisible="not include_taxes_product"/>
                    </group>

                    <group string="Products to publish" col="1">
                        <field name="product_count" readonly="1" string="Total selected products"/>
                        <field name="product_tmpl_ids" readonly="1" nolabel="1">
                            <tree create="false" delete="false" editable="false">
                                <field name="default_code" string="SKU" optional="show"/>
                                <field name="name" string="Name"/>
                                <field name="list_price" string="Price" widget="monetary"/>
                                <field name="woo_published_count" string="WC Instances" optional="show"/>
                            </tree>
                        </field>
                    </group>

                    <div class="alert alert-warning mt-2" role="status">
                        <i class="fa fa-exclamation-triangle me-1"/>
                        Products that already exist in the selected instance
                        will be <strong>updated</strong>, not duplicated.
                    </div>
                </sheet>
                <footer>
                    <button name="action_bulk_publish" string="Publish all" type="object" class="btn-primary" data-hotkey="q"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
