<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Generic confirmation wizard view -->
    <record id="view_confirmation_wizard_form" model="ir.ui.view">
        <field name="name">confirmation.wizard.form</field>
        <field name="model">confirmation.wizard</field>
        <field name="arch" type="xml">
            <form string="Confirmation">
                <style>
                    .confirmation_wizard_container {
                        padding: 30px 20px;
                        text-align: center;
                    }
                    .confirmation_wizard_icon {
                        font-size: 48px;
                        color: #f0ad4e;
                        margin-bottom: 20px;
                    }
                    .confirmation_wizard_title {
                        font-size: 24px;
                        font-weight: 600;
                        color: #2c3e50;
                        margin-bottom: 15px;
                    }
                    .confirmation_wizard_description {
                        font-size: 15px;
                        color: #5f6368;
                        line-height: 1.6;
                        max-width: 500px;
                        margin: 0 auto 25px;
                    }
                    .modal-footer {
                        border-top: 1px solid #e9ecef;
                        padding-top: 15px;
                        margin-top: 20px;
                    }
                </style>
                <sheet>
                    <div class="confirmation_wizard_container">
                        <!-- Confirmation icon -->
                        <div class="confirmation_wizard_icon">
                            <i class="fa fa-question-circle" title="Confirmation"/>
                        </div>

                        <!-- Title -->
                        <div class="confirmation_wizard_title">
                            <field name="title" readonly="1" nolabel="1"/>
                        </div>

                        <!-- Description -->
                        <div class="confirmation_wizard_description">
                            <field name="description" readonly="1" nolabel="1"/>
                        </div>
                    </div>

                    <!-- Hidden fields for internal operation -->
                    <group invisible="1">
                        <field name="model_name"/>
                        <field name="method_name"/>
                        <field name="record_id"/>
                        <field name="context_data"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_confirm" type="object" string="Confirm" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Action for the generic confirmation wizard -->
    <record id="action_confirmation_wizard" model="ir.actions.act_window">
        <field name="name">Confirmation</field>
        <field name="res_model">confirmation.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>