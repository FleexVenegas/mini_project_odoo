<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_woo_link_wizard_form" model="ir.ui.view">
        <field name="name">woo.link.wizard.form</field>
        <field name="model">woo.link.wizard</field>
        <field name="arch" type="xml">
            <form string="Vincular producto WooCommerce">
                <sheet>
                    <div class="oe_title">
                        <h1>Vincular producto a Odoo</h1>
                        <p class="text-muted">
                            Seleccione el producto de Odoo que corresponde a este
                            producto de WooCommerce y confirme el vínculo.
                        </p>
                    </div>

                    <group string="Producto WooCommerce" col="2">
                        <field name="woo_product_id" invisible="1"/>
                        <field name="woo_name" readonly="1"/>
                        <field name="woo_sku" readonly="1"/>
                        <field name="woo_price" readonly="1" widget="monetary"/>
                    </group>

                    <group string="Producto en Odoo" col="2">
                        <field name="product_tmpl_id" options="{'no_create': True}" placeholder="Buscar por nombre o referencia interna…"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_link" string="Vincular" type="object" class="btn-primary" data-hotkey="q"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
