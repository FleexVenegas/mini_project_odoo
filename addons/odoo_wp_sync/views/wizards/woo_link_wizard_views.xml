<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_woo_link_wizard_form" model="ir.ui.view">
        <field name="name">woo.link.wizard.form</field>
        <field name="model">woo.link.wizard</field>
        <field name="arch" type="xml">
            <form string="Link WooCommerce Product">
                <sheet>
                    <div class="oe_title">
                        <h1>Link product to Odoo</h1>
                        <p class="text-muted">
                            Select the Odoo product that corresponds to this
                            WooCommerce product and confirm the link.
                        </p>
                    </div>

                    <group string="WooCommerce Product" col="2">
                        <field name="woo_product_id" invisible="1"/>
                        <field name="woo_name" readonly="1"/>
                        <field name="woo_sku" readonly="1"/>
                        <field name="woo_price" readonly="1" widget="monetary"/>
                    </group>

                    <group string="Product in Odoo" col="2">
                        <field name="product_tmpl_id" options="{'no_create': True}" placeholder="Search by name or internal reference…"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_link" string="Link" type="object" class="btn-primary" data-hotkey="q"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
