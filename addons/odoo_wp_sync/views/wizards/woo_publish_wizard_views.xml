<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_woo_publish_wizard_form" model="ir.ui.view">
        <field name="name">woo.publish.wizard.form</field>
        <field name="model">woo.publish.wizard</field>
        <field name="arch" type="xml">
            <form string="Publish to WooCommerce">
                <sheet>
                    <div class="oe_title">
                        <h1>Publish product to WooCommerce</h1>
                        <p class="text-muted">
                            Choose the target instance and configure the options
                            before sending the product.
                        </p>
                    </div>

                    <group string="Selected product" col="2">
                        <field name="product_tmpl_id" invisible="1"/>
                        <field name="product_name" readonly="1"/>
                        <field name="product_sku" readonly="1"/>
                        <field name="product_price" readonly="1" widget="monetary"/>
                    </group>

                    <group string="Publishing settings" col="2">
                        <field name="instance_id" options="{'no_create': True}" placeholder="Select instance…"/>
                        <field name="pricelist_id" readonly="1" string="Pricelist (instance)"/>
                        <field name="pricelist_price" readonly="1" widget="monetary" string="Price per list"/>
                        <field name="wc_status" widget="radio"/>
                        <field name="price_override" widget="monetary" placeholder="0 = use pricelist price"/>
                        <field name="include_taxes_product" invisible="1"/>
                        <field name="taxes_product" readonly="1" widget="many2many_tags" string="Taxes to apply" invisible="not include_taxes_product"/>
                    </group>

                    <group string="Product description">

                        <field name="description" />
                    </group>

                    <div class="alert alert-info" role="status">
                        <i class="fa fa-info-circle me-1"/>
                        If this product already exists in the selected instance,
                        it will be updated instead of creating a new one.<br/>
                        The price will be taken from the <strong>pricelist configured in the instance</strong>
                        (Sales tab). If no pricelist is configured, the product list price is used.
                        You can override the price manually in the field above.
                </div>
            </sheet>
            <footer>
                <button name="action_publish" string="Publish to WooCommerce" type="object" class="btn-primary" data-hotkey="q"/>
                <button string="Cancel" class="btn-secondary" special="cancel"/>
            </footer>
        </form>
    </field>
</record>
</odoo>
