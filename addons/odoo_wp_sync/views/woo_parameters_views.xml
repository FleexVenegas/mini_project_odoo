<?xml version="1.0" encoding="utf-8"?>
<odoo>


    <!-- Vista tree -->
    <record id="view_odoo_wp_sync_parameters_tree" model="ir.ui.view">
        <field name="name">odoo.wp.sync.parameters.tree</field>
        <field name="model">odoo.wp.sync.parameters</field>
        <field name="arch" type="xml">
            <tree string="WooCommerce Sync Parameters">
                <field name="name"/>
                <field name="value"/>
            </tree>
        </field>
    </record>

    <!-- Vista form -->
    <record id="view_odoo_wp_sync_parameters_form" model="ir.ui.view">
        <field name="name">odoo.wp.sync.parameters.form</field>
        <field name="model">odoo.wp.sync.parameters</field>
        <field name="arch" type="xml">
            <form string="WooCommerce Sync Parameter">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="value"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>



    <!-- Actions -->
    <record id="action_odoo_wp_sync_parameters" model="ir.actions.act_window">
        <field name="name">WooCommerce Sync Parameters</field>
        <field name="res_model">odoo.wp.sync.parameters</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{}</field>

    </record>

</odoo>
