<odoo>

    <!-- Vista Tree -->
    <record id="view_odoo_wp_sync_tree" model="ir.ui.view">
        <field name="name">odoo_wp_sync.tree</field>
        <field name="model">odoo.wp.sync</field>
        <field name="arch" type="xml">
            <tree string="WooCommerce Orders" default_order="date_created desc" multi_edit="1">
                <header>
                    <button name="action_open_create_sale_order_wizard" type="object" string="Create Orders" class="btn-secondary" icon="fa-plus"/>
                    <button name="action_wc_mark_processing" type="object" string="→ Processing"/>
                    <button name="action_wc_mark_completed" type="object" string="→ Completed"/>
                    <button name="action_wc_mark_on_hold" type="object" string="→ On Hold"/>
                    <button name="action_wc_mark_cancelled" type="object" string="→ Cancel in WC"/>
                </header>
                <field name="instance_id" string="Instance" optional="show"/>
                <field name="name" string="Order"/>
                <field name="total" string="Total" widget="monetary" options="{'currency_field': 'currency'}"/>
                <field name="currency" string="Currency"/>
                <field name="date_created" string="Date"/>
                <field name="status" string="Status" widget="badge" decoration-info="status in ('pending', 'on-hold')" decoration-success="status == 'completed'" decoration-warning="status == 'processing'" decoration-danger="status in ('cancelled', 'refunded', 'failed')"/>
                <field name="sale_order_id" string="Odoo Order" readonly="1"/>
            </tree>
        </field>
    </record>

    <!-- Vista Form -->
    <record id="view_odoo_wp_sync_form" model="ir.ui.view">
        <field name="name">odoo_wp_sync.form</field>
        <field name="model">odoo.wp.sync</field>
        <field name="arch" type="xml">
            <form string="WooCommerce Order">
                <header>
                    <button name="action_open_create_sale_order_wizard" type="object" string="Create Odoo Order" class="btn-primary" invisible="sale_order_id or status in ('failed', 'refunded', 'cancelled')" />

                    <!-- Change status in WooCommerce -->
                    <button name="action_wc_mark_processing" type="object" string="Mark as Processing" class="btn-secondary" invisible="status == 'processing'"/>
                    <button name="action_wc_mark_completed" type="object" string="Mark as Completed" class="btn-secondary" invisible="status == 'completed'"/>
                    <button name="action_wc_mark_on_hold" type="object" string="Put On Hold" class="btn-secondary" invisible="status in ('on-hold', 'cancelled', 'refunded', 'failed')"/>
                    <button name="action_wc_mark_cancelled" type="object" string="Cancel in WC" class="btn-secondary" invisible="status in ('cancelled', 'refunded', 'failed')"/>
                    <button name="action_wc_mark_refunded" type="object" string="Mark as Refunded" class="btn-secondary" invisible="status in ('refunded', 'cancelled', 'failed')"/>

                    <field name="status" widget="statusbar" options="{'clickable': '0'}" statusbar_visible="pending,processing,completed"/>
                </header>

                <sheet>
                    <div name="button_box" class="oe_button_box">
                        <button name="action_open_sale_order" type="object" class="oe_stat_button" icon="fa-shopping-cart" invisible="not sale_order_id">
                            <div class="o_field_widget o_stat_info">
                                <span class="o_stat_text">View Order</span>
                                <field name="sale_order_id" nolabel="1" readonly="1" no_open="0"/>
                            </div>
                        </button>
                    </div>

                    <!-- Title Section with Total Amount -->
                    <div class="oe_title mb-3">
                        <div class="row">
                            <div class="col-8">
                                <label for="order_number" class="oe_edit_only"/>
                                <h1 class="d-flex align-items-center">
                                    <span class="me-2">Order</span>
                                    <field name="order_number" readonly="1" class="text-break" placeholder="Order number"/>
                                </h1>
                            </div>
                            <div class="col-4 text-end">
                                <div class="d-flex flex-column align-items-end">
                                    <span class="text-muted" style="font-size: 14px;">Order Total</span>
                                    <h1 class="mb-0" style="font-weight: bold; color: #000;">
                                        <field name="total" widget="monetary" options="{'currency_field': 'currency'}" readonly="1" nolabel="1"/>
                                        <field name="currency" invisible="1"/>
                                    </h1>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Summary Card -->
                    <div class="o_group">
                        <group>
                            <group string="Instance &amp; Customer Info" class="mb-4">
                                <field name="instance_id" readonly="1"/>
                                <field name="customer_name" string="Name" readonly="1"/>
                                <field name="customer_email" string="Email" widget="email" readonly="1"/>
                                <field name="customer_phone" string="Phone" widget="phone" readonly="1"/>
                            </group>
                            <group string="Order Details" class="mb-4">
                                <field name="wc_order_id" string="ID WooCommerce" readonly="1"/>
                                <field name="date_created" string="Creation Date" readonly="1"/>
                                <field name="payment_method" string="Payment Method" readonly="1"/>
                                <field name="created_via" string="Source" readonly="1"/>
                            </group>
                        </group>
                    </div>

                    <notebook>
                        <!-- Order Items -->
                        <page string="Products" name="items">
                            <field name="line_ids" nolabel="1" readonly="1">
                                <tree string="Order Lines" create="false" delete="false" edit="false" no_open="true" decoration-info="line_type == 'shipping'">
                                    <field name="line_type" column_invisible="1"/>
                                    <field name="name" string="Product"/>
                                    <field name="sku" string="SKU"/>
                                    <field name="quantity" string="Quantity"/>
                                    <field name="price" string="Unit Price" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                    <field name="subtotal" string="Subtotal" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                    <field name="total_tax" string="Tax" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                    <field name="total" string="Total" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                    <field name="currency_id" column_invisible="1"/>
                                </tree>
                            </field>
                        </page>

                        <!-- Shipping Information -->
                        <page string="Shipping Address" name="shipping">

                            <field name="shipping_address" nolabel="1" readonly="1" placeholder="The shipping address will appear here..." options="{'resizable': False}"/>

                        </page>

                        <!-- Technical Data -->
                        <page string="Technical Data" name="technical_data" groups="base.group_no_one">
                            <group>
                                <field name="synced_date" string="Last Sync" readonly="1"/>
                            </group>
                            <separator string="Full WooCommerce JSON"/>
                            <field name="raw_data" nolabel="1" readonly="1" widget="ace" options="{'language': 'json'}" placeholder="Data in JSON format..."/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search view (filters and grouping) -->
    <record id="view_odoo_wp_sync_search" model="ir.ui.view">
        <field name="name">odoo_wp_sync.search</field>
        <field name="model">odoo.wp.sync</field>
        <field name="arch" type="xml">
            <search string="Search Orders">
                <field name="name"/>
                <field name="order_number"/>
                <field name="customer_name"/>
                <field name="customer_email"/>
                <field name="instance_id"/>

                <filter string="Pending" name="filter_pending" domain="[('status', 'in', ['pending', 'on-hold'])]"/>
                <filter string="Processing" name="filter_processing" domain="[('status', '=', 'processing')]"/>
                <filter string="Completed" name="filter_completed" domain="[('status', '=', 'completed')]"/>

                <separator/>
                <filter string="Today" name="filter_today" domain="[('date_created', '&gt;=', context_today().strftime('%Y-%m-%d 00:00:00'))]"/>
                <filter string="This Week" name="filter_week" domain="[('date_created', '&gt;=', (context_today() - relativedelta(weeks=1)).strftime('%Y-%m-%d 00:00:00'))]"/>

                <group expand="0" string="Group By">
                    <filter string="Instance" name="group_instance" context="{'group_by': 'instance_id'}"/>
                    <filter string="Status" name="group_status" context="{'group_by': 'status'}"/>
                    <filter string="Date" name="group_date" context="{'group_by': 'date_created:day'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_odoo_wp_sync" model="ir.actions.act_window">
        <field name="name">WooCommerce Orders</field>
        <field name="res_model">odoo.wp.sync</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No orders synchronized yet
            </p>
            <p>
                Click on "Sync Now" in the menu to import orders from WooCommerce.
            </p>
        </field>
    </record>


    <!-- Action to open the sync confirmation wizard -->
    <record id="action_server_woo_sync_wizard" model="ir.actions.server">
        <field name="name">Sync WooCommerce</field>
        <field name="model_id" ref="model_odoo_wp_sync"/>
        <field name="state">code</field>
        <field name="code">
action = model.action_open_sync_wizard()
        </field>
    </record>

    <!-- Server action for sync from menu -->
    <record id="action_server_sync_woocommerce" model="ir.actions.server">
        <field name="name">Sync with WooCommerce</field>
        <field name="model_id" ref="model_odoo_wp_sync"/>
        <field name="state">code</field>
        <field name="code">
action = model.action_open_sync_wizard()
        </field>
    </record>

</odoo>