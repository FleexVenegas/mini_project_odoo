<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ── Action ─────────────────────────────────────────────────────────── -->
    <record id="action_woo_category" model="ir.actions.act_window">
        <field name="name">WooCommerce Categories</field>
        <field name="res_model">woo.category</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No categories registered yet
            </p>
            <p>
                Categories are created automatically when syncing products,
                or you can create them manually here to assign them to your products.
            </p>
        </field>
    </record>

    <!-- ── Tree ───────────────────────────────────────────────────────────── -->
    <record id="view_woo_category_tree" model="ir.ui.view">
        <field name="name">woo.category.tree</field>
        <field name="model">woo.category</field>
        <field name="arch" type="xml">
            <tree string="WooCommerce Categories" decoration-muted="not woo_id">
                <field name="instance_id" string="Instance" optional="show"/>
                <field name="complete_name" string="Category"/>
                <field name="slug" string="Slug" optional="show"/>
                <field name="parent_id" string="Parent" optional="show"/>
                <field name="woo_id" string="WC ID" optional="show"/>
            </tree>
        </field>
    </record>

    <!-- ── Form ───────────────────────────────────────────────────────────── -->
    <record id="view_woo_category_form" model="ir.ui.view">
        <field name="name">woo.category.form</field>
        <field name="model">woo.category</field>
        <field name="arch" type="xml">
            <form string="WooCommerce Category">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Category name"/>
                        </h1>
                    </div>
                    <group>
                        <group string="WooCommerce">
                            <field name="instance_id"/>
                            <field name="woo_id" string="WooCommerce ID" readonly="1"/>
                            <field name="slug" string="Slug"/>
                        </group>
                        <group string="Hierarchy">
                            <field name="parent_id" options="{'no_create': True}"/>
                            <field name="child_ids" string="Subcategories" readonly="1"/>
                        </group>
                    </group>
                    <group string="Full path">
                        <field name="complete_name" readonly="1" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ── Search ─────────────────────────────────────────────────────────── -->
    <record id="view_woo_category_search" model="ir.ui.view">
        <field name="name">woo.category.search</field>
        <field name="model">woo.category</field>
        <field name="arch" type="xml">
            <search string="Search Categories">
                <field name="name" string="Name"/>
                <field name="slug" string="Slug"/>
                <field name="instance_id" string="Instance"/>
                <separator/>
                <filter name="root_only" string="Root only" domain="[('parent_id', '=', False)]"/>
                <filter name="with_woo_id" string="Synced" domain="[('woo_id', '!=', 0)]"/>
                <group expand="0" string="Group By">
                    <filter name="group_instance" string="Instance" context="{'group_by': 'instance_id'}"/>
                    <filter name="group_parent" string="Parent" context="{'group_by': 'parent_id'}"/>
                </group>
            </search>
        </field>
    </record>


</odoo>
