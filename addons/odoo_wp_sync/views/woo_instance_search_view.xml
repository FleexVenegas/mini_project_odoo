<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Search View -->
    <record id="view_woo_instance_search" model="ir.ui.view">
        <field name="name">woo.instance.search</field>
        <field name="model">woo.instance</field>
        <field name="arch" type="xml">
            <search string="WooCommerce Instances">
                <field name="name" string="Instance" filter_domain="['|', ('name', 'ilike', self), ('wp_url', 'ilike', self)]"/>
                <filter string="Connected" name="connected" domain="[('state', '=', 'connected')]"/>
                <filter string="Draft" name="draft" domain="[('state', '=', 'draft')]"/>
                <filter string="Error" name="error" domain="[('state', '=', 'error')]"/>
                <separator/>
                <filter string="Archived" name="inactive" domain="[('active', '=', False)]"/>
                <group expand="0" string="Group By">
                    <filter string="Status" name="group_state" context="{'group_by': 'state'}"/>
                    <filter string="Company" name="group_company" context="{'group_by': 'company_id'}" groups="base.group_multi_company"/>
                </group>
            </search>
        </field>
    </record>

</odoo>
