<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_activo_fijo_responsiva_tree" model="ir.ui.view">
        <field name="name">activo.fijo.responsiva.tree</field>
        <field name="model">activo.fijo.responsiva</field>
        <field name="arch" type="xml">
            <tree string="Asset Accountabilities">
                <field name="activo_folio"/>
                <field name="activo_id" optional="hide"/>
                <field name="responsable_id"/>
                <field name="fecha_asignacion"/>
                <field name="estado"/>
                <field name="observaciones" optional="hide"/>
            </tree>
        </field>
    </record>

    <record id="view_activo_fijo_responsiva_form" model="ir.ui.view">
        <field name="name">activo.fijo.responsiva.form</field>
        <field name="model">activo.fijo.responsiva</field>
        <field name="arch" type="xml">
            <form string="Asset Accountability">
                <sheet>
                    <field name="activo_image" widget="image" class="oe_avatar" options="{'preview_image': 'activo_image'}"/>
                    <div class="oe_title">
                        <label for="activo_id" string="Asset"/>
                        <h1>
                            <field name="activo_id" required="1" options="{'no_create': True}"/>
                        </h1>
                    </div>

                    <group>
                        <group string="Assignment Information">
                            <field name="responsable_id" required="1"/>
                            <field name="fecha_asignacion" required="1"/>
                            <field name="estado"/>
                        </group>
                        <group string="Document">
                            <field name="responsiva_pdf" filename="pdf_filename" widget="binary" options="{'accepted_file_extensions': '.pdf'}"/>
                            <field name="pdf_filename" invisible="1"/>
                        </group>
                    </group>

                    <separator string="Notes"/>
                    <field name="observaciones" nolabel="1" placeholder="Additional notes about the accountability..."/>
                </sheet>
                <!-- Chatter (if you have it configured) -->
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="action_activo_fijo_responsiva" model="ir.actions.act_window">
        <field name="name">Asset Accountabilities</field>
        <field name="res_model">activo.fijo.responsiva</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>
