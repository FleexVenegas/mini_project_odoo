<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_activo_fijo_traslado_tree" model="ir.ui.view">
        <field name="name">activo.fijo.traslado.tree</field>
        <field name="model">activo.fijo.traslado</field>
        <field name="arch" type="xml">
            <tree string="Traslados de Activos">
                <field name="activo_folio"/>
                <field name="activo_id" optional="hide"/>
                <field name="fecha"/>
                <field name="origen_responsable_id"/>
                <field name="destino_responsable_id"/>
                <field name="origen_almacen_id" options="{'no_create': True}"/>
                <field name="destino_almacen_id" options="{'no_create': True}"/>
                <field name="motivo"/>
            </tree>
        </field>
    </record>

    <record id="view_activo_fijo_traslado_form" model="ir.ui.view">
        <field name="name">activo.fijo.traslado.form</field>
        <field name="model">activo.fijo.traslado</field>
        <field name="arch" type="xml">
            <form string="Traslado de Activo">
                <sheet>
                    <div class="oe_title">
                        <label for="activo_id" string="Activo a Trasladar"/>
                        <h1>
                            <field name="activo_id" required="1" options="{'no_create': True}"/>
                        </h1>
                    </div>

                    <group>
                        <field name="fecha" required="1"/>
                    </group>

                    <group>
                        <group string="Origen (Actual)">
                            <field name="origen_responsable_id" readonly="1"/>
                            <field name="origen_almacen_id" options="{'no_create': True}" readonly="1"/>
                        </group>
                        <group string="Destino (Nuevo)">
                            <field name="destino_responsable_id"/>
                            <field name="destino_almacen_id" options="{'no_create': True}"/>
                        </group>
                    </group>

                    <separator string="Motivo del Traslado"/>
                    <field name="motivo" required="1" nolabel="1" placeholder="Describe el motivo del traslado del activo..."/>
                </sheet>
                <!-- Chatter (si lo tienes configurado) -->
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="action_activo_fijo_traslado" model="ir.actions.act_window">
        <field name="name">Traslados de Activos</field>
        <field name="res_model">activo.fijo.traslado</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>
