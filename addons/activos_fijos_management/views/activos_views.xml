<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_activo_fijo_tree" model="ir.ui.view">
        <field name="name">activo.fijo.tree</field>
        <field name="model">activo.fijo</field>
        <field name="arch" type="xml">
            <tree string="Fixed Assets" editable="bottom">
                <!-- <field name="id"/> -->
                <field name="display_name" placeholder="E.g: HP Laptop 2022"/>
                <field name="categoria_id"/>
                <field name="responsable_id"/>
                <field name="almacen_id"/>
                <field name="estado"/>
                <field name="costo"/>
                <field name="fecha_adquisicion"/>
            </tree>
        </field>
    </record>

    <record id="view_activo_fijo_kanban" model="ir.ui.view">
        <field name="name">activo.fijo.kanban</field>
        <field name="model">activo.fijo</field>
        <field name="arch" type="xml">
            <kanban class="o_custom_activo_fijo_kanban">
                <field name="id"/>
                <field name="name"/>
                <field name="estado"/>
                <field name="categoria_id"/>
                <field name="responsable_id"/>
                <field name="fecha_adquisicion"/>
                <field name="image_1920"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click" t-att-data-id="record.id.raw_value">
                            <div class="o_kanban_image">
                                <img t-att-src="kanban_image('activo.fijo', 'image_1920', record.id.raw_value)" alt="Asset"/>
                            </div>
                            <div class="oe_kanban_details">
                                <strong class="o_kanban_record_title">
                                    <field name="name"/>
                                </strong>
                                <div class="o_kanban_tags_section">
                                    <field name="categoria_id"/>
                                </div>
                                <ul>
                                    <li>Responsible: <field name="responsable_id"/>
                                    </li>
                                    <li>Status: <field name="estado" widget="badge" decoration-success="estado == 'disponible'" decoration-warning="estado == 'en_uso'" decoration-danger="estado == 'mantenimiento'"/>
                                    </li>
                                </ul>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_activo_fijo_form" model="ir.ui.view">
        <field name="name">activo.fijo.form</field>
        <field name="model">activo.fijo</field>
        <field name="arch" type="xml">
            <form string="Fixed Asset">
                <sheet>
                    <!-- Header with image and main fields -->
                    <field name="image_1920" widget="image" class="oe_avatar" options="{'preview_image': 'image_1920'}"/>
                    <div class="oe_title">
                        <label for="name" string="Folio"/>
                        <h1>
                            <field name="name" readonly="1" class="oe_inline"/>
                        </h1>
                        <label for="display_name" string="Asset Name"/>
                        <h2>
                            <field name="display_name" required="1"/>
                        </h2>
                        <label for="uuid" string="Asset ID"/>
                        <h2>
                            <field name="uuid" required="1" placeholder="E.g: 9433BA08-AC84-5E04-8BC1, 863478062395409, X7AT447182"/>
                        </h2>
                    </div>

                    <group>
                        <group string="General Information">
                            <field name="categoria_id" required="1"/>
                            <field name="estado"/>
                            <field name="responsable_id"/>
                            <field name="departamento_id" options="{'no_create': True}"/>
                            <field name="almacen_id" options="{'no_create': True}"/>
                        </group>

                        <group string="Financial Information">
                            <field name="fecha_adquisicion"/>
                            <field name="costo" widget="monetary"/>
                            <field name="cuenta_contable_id"/>
                        </group>
                    </group>

                    <group>
                        <field name="descripcion" placeholder="Detailed asset description..."/>
                    </group>

                    <notebook>
                        <page string="Accountabilities" name="responsivas">
                            <field name="responsiva_ids">
                                <tree>
                                    <field name="fecha_asignacion"/>
                                    <field name="responsable_id"/>
                                    <field name="estado"/>
                                    <field name="observaciones" optional="hide"/>
                                </tree>
                                <form string="Accountability">
                                    <sheet>
                                        <group>
                                            <group>
                                                <field name="responsable_id" required="1"/>
                                                <field name="fecha_asignacion" required="1"/>
                                                <field name="estado"/>
                                            </group>
                                            <group>
                                                <field name="responsiva_pdf" filename="pdf_filename" widget="binary" options="{'accepted_file_extensions': '.pdf'}"/>
                                                <field name="pdf_filename" invisible="1"/>
                                            </group>
                                        </group>
                                        <group>
                                            <field name="observaciones" placeholder="Additional notes..."/>
                                        </group>
                                    </sheet>
                                </form>
                            </field>
                        </page>
                    </notebook>
                </sheet>

                <!-- Chatter (if you have it configured) -->
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>



    <record id="action_activo_fijo" model="ir.actions.act_window">
        <field name="name">Fixed Assets</field>
        <field name="res_model">activo.fijo</field>
        <field name="view_mode">kanban,tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Register and manage the company's fixed assets.
            </p>
        </field>
    </record>
</odoo>
