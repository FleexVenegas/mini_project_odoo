<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Tarea programada: Recalcular Fill Rate diariamente -->
        <record id="ir_cron_recalculate_fill_rate" model="ir.cron">
            <field name="name">Fill Rate: Recalcular automáticamente</field>
            <field name="model_id" ref="model_res_partner"/>
            <field name="state">code</field>
            <field name="code">
# Recalcular fill rate de todos los proveedores con órdenes de compra
partners = env['res.partner'].search([
    ('is_company', '=', True),
    ('fill_rate_history_ids', '!=', False)
])

for partner in partners:
    partner.recalculate_fill_rate()
            </field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="active" eval="True"/>
            <field name="doall" eval="False"/>
        </record>

    </data>
</odoo>
