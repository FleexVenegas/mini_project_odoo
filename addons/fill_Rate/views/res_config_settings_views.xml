<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Inherited view to add Fill Rate configuration -->
        <record id="res_config_settings_view_form_fill_rate" model="ir.ui.view">
            <field name="name">res.config.settings.view.form.inherit.fill.rate</field>
            <field name="model">res.config.settings</field>
            <field name="priority" eval="200"/>
            <field name="inherit_id" ref="base.res_config_settings_view_form"/>
            <field name="arch" type="xml">
                <xpath expr="//form" position="inside">
                    <app string="Fill Rate" name="fill_Rate" groups="base.group_system" icon="/fill_Rate/static/description/icon.png">
                        <block title="Supplier Classification Settings">
                            <setting id="fill_rate_threshold_setting" help="Configure the thresholds to classify suppliers by their Fill Rate">
                                <div class="content-group">
                                    <div class="row mt16">
                                        <label string="Threshold A - Excellent (≥)" for="fill_rate_threshold_a" class="col-lg-4 o_light_label"/>
                                        <field name="fill_rate_threshold_a" class="oe_inline"/>
 %
                                        <span class="text-muted ms-2">Suppliers with fill rate greater than or equal to this value</span>
                                    </div>
                                    <div class="row mt16">
                                        <label string="Threshold B - Good (≥)" for="fill_rate_threshold_b" class="col-lg-4 o_light_label"/>
                                        <field name="fill_rate_threshold_b" class="oe_inline"/>
 %
                                        <span class="text-muted ms-2">Suppliers between this value and Threshold A</span>
                                    </div>
                                    <div class="alert alert-info mt16" role="alert">
                                        <strong>Resulting Classification:</strong>
                                        <ul class="mb-0 mt-2">
                                            <li>
                                                <span class="badge badge-success">A - Excellent</span>: Fill Rate ≥ <field name="fill_rate_threshold_a" readonly="1" nolabel="1" class="oe_inline"/>
%</li>
                                            <li>
                                                <span class="badge badge-warning">B - Good</span>:                                                <field name="fill_rate_threshold_b" readonly="1" nolabel="1" class="oe_inline"/>
% ≤ Fill Rate &lt; <field name="fill_rate_threshold_a" readonly="1" nolabel="1" class="oe_inline"/>
%</li>
                                            <li>
                                                <span class="badge badge-danger">C - Poor</span>: Fill Rate &lt; <field name="fill_rate_threshold_b" readonly="1" nolabel="1" class="oe_inline"/>
%</li>
                                        </ul>
                                    </div>
                                </div>
                            </setting>
                        </block>
                    </app>
                </xpath>
            </field>
        </record>

        <!-- Action to open Fill Rate configuration -->
        <record id="action_fill_rate_configuration" model="ir.actions.act_window">
            <field name="name">Fill Rate Configuration</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">res.config.settings</field>
            <field name="view_mode">form</field>
            <field name="target">inline</field>
            <field name="context">{'module': 'fill_Rate'}</field>
        </record>
    </data>
</odoo>
