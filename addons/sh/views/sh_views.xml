<odoo>

    <!-- Acción primero (evita ParseError) -->
    <record id="action_sh" model="ir.actions.act_window">
        <field name="name">Sh</field>
        <field name="res_model">sh</field>
        <field name="view_mode">tree,form</field>
    </record>

    <!-- Vista Tree -->
    <record id="view_sh_tree" model="ir.ui.view">
        <field name="name">sh.tree</field>
        <field name="model">sh</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
            </tree>
        </field>
    </record>

    <!-- Menú raíz -->
    <menuitem id="sh_menu_root" name="Sh"/>

    <!-- Submenú -->
    <menuitem 
        id="sh_menu_modelo" 
        name="Registros"
        parent="sh_menu_root"
        action="action_sh"
    />

</odoo>
