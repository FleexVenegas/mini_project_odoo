<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Definición del reporte -->
    <record id="action_report_receipts" model="ir.actions.report">
        <field name="name">Payment Receipt</field>
        <field name="model">receipts</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">receipts.report_receipts_document</field>
        <field name="report_file">receipts.report_receipts_document</field>
        <field name="binding_model_id" ref="model_receipts"/>
        <field name="binding_type">report</field>
        <field name="print_report_name">'Receipt - %s' % (object.name)</field>
    </record>

    <!-- Template del reporte -->
    <template id="report_receipts_document">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.basic_layout">
                    <div class="page" style="font-family: 'Helvetica', 'Arial', sans-serif; padding-left: 40px; padding-right: 40px; color: #222;">

                        <!-- Logo y Encabezado -->
                        <div style="display: table; width: 100%; margin-bottom: 40px; padding-bottom: 20px; border-bottom: 2px solid #999;">
                            <div style="display: table-cell; width: 50%; vertical-align: middle;">
                                <img t-if="doc.env.company.logo" t-att-src="image_data_uri(doc.env.company.logo)" style="max-height: 80px; max-width: 250px;" alt="Logo"/>
                            </div>
                            <div style="display: table-cell; width: 50%; text-align: right; vertical-align: middle;">
                                <div style="font-size: 13pt; color: #444; margin-bottom: 5px; font-weight: 500;">Folio</div>
                                <div style="font-size: 24pt; font-weight: 400; letter-spacing: 2px; color: #000;">
                                    <span t-field="doc.name"/>
                                </div>
                            </div>
                        </div>

                        <!-- Title -->
                        <div style="margin-bottom: 40px;">
                            <h1 style="font-size: 32pt; font-weight: 400; margin: 0; letter-spacing: 1px; color: #000;">PAYMENT RECEIPT</h1>
                        </div>

                        <!-- Información principal -->
                        <table style="width: 100%; margin-bottom: 40px; border-collapse: collapse; border: .5px solid #fff;">
                            <tr>
                                <td style="padding: 18px 0; border-bottom: 2px solid #ccc; border-left: 0; border-right: 0; border-top: 0; width: 30%; vertical-align: top;">
                                    <div style="font-size: 12pt; color: #444; text-transform: uppercase; letter-spacing: 1px; font-weight: 500;">Received from</div>
                                </td>
                                <td style="padding: 18px 0; border-bottom: 2px solid #ccc; border-left: 0; border-right: 0; border-top: 0;">
                                    <div style="font-size: 15pt; font-weight: 400; color: #000;">
                                        <span t-field="doc.client_id.name"/>
                                    </div>
                                </td>
                            </tr>
                            <tr>
                                <td style="padding: 18px 0; border-bottom: 2px solid #ccc; border-left: 0; border-right: 0; border-top: 0; vertical-align: top;">
                                    <div style="font-size: 12pt; color: #444; text-transform: uppercase; letter-spacing: 1px; font-weight: 500;">Date</div>
                                </td>
                                <td style="padding: 18px 0; border-bottom: 2px solid #ccc; border-left: 0; border-right: 0; border-top: 0;">
                                    <div style="font-size: 15pt; color: #000;">
                                        <span t-field="doc.date" t-options='{"format": "dd/MM/yyyy"}'/>
                                    </div>
                                </td>
                            </tr>
                            <tr>
                                <td style="padding: 18px 0; border-bottom: 2px solid #ccc; border-left: 0; border-right: 0; border-top: 0; vertical-align: top;">
                                    <div style="font-size: 12pt; color: #444; text-transform: uppercase; letter-spacing: 1px; font-weight: 500;">Amount</div>
                                </td>
                                <td style="padding: 18px 0; border-bottom: 2px solid #ccc; border-left: 0; border-right: 0; border-top: 0;">
                                    <div style="font-size: 28pt; font-weight: 400; color: #000;">
                                        $                                        <t t-esc="'{:,.2f}'.format(doc.total_amount)"/>
                                    </div>
                                </td>
                            </tr>
                            <tr>
                                <td style="padding: 18px 0; border-bottom: 2px solid #ccc; border-left: 0; border-right: 0; border-top: 0; vertical-align: top;">
                                    <div style="font-size: 12pt; color: #444; text-transform: uppercase; letter-spacing: 1px; font-weight: 500;">In words</div>
                                </td>
                                <td style="padding: 18px 0; border-bottom: 2px solid #ccc; border-left: 0; border-right: 0; border-top: 0;">
                                    <div style="font-size: 13pt; font-style: italic; color: #333;">
                                        <span t-field="doc.amount_to_text"/>
                                    </div>
                                </td>
                            </tr>
                            <tr t-if="doc.payment_method">
                                <td style="padding: 18px 0; border-bottom: 2px solid #ccc; border-left: 0; border-right: 0; border-top: 0; vertical-align: top;">
                                    <div style="font-size: 12pt; color: #444; text-transform: uppercase; letter-spacing: 1px; font-weight: 500;">Payment Method</div>
                                </td>
                                <td style="padding: 18px 0; border-bottom: 2px solid #ccc; border-left: 0; border-right: 0; border-top: 0;">
                                    <div style="font-size: 15pt; color: #000;">
                                        <span t-field="doc.payment_method"/>
                                    </div>
                                </td>
                            </tr>
                            <tr>
                                <td style="padding: 18px 0; border: 0; vertical-align: top;">
                                    <div style="font-size: 12pt; color: #444; text-transform: uppercase; letter-spacing: 1px; font-weight: 500;">Concept</div>
                                </td>
                                <td style="padding: 18px 0; border: 0;">
                                    <div style="font-size: 14pt; line-height: 1.6; color: #222;">
                                        <span t-field="doc.concept"/>
                                    </div>
                                </td>
                            </tr>
                        </table>

                        <!-- Firma -->
                        <div style="margin-top: 80px; margin-bottom: 30px;">
                            <div style="width: 300px; margin: 0 auto; text-align: center;">
                                <div style="border-top: 2px solid #000; padding-top: 12px; margin-bottom: 8px;">
                                    <span style="font-size: 12pt; color: #444; font-weight: 500;">Signature</span>
                                </div>
                                <div style="font-size: 14pt; font-weight: 400; color: #000; margin-bottom: 5px;">
                                    <span t-field="doc.user_id.name"/>
                                </div>
                                <div t-if="doc.department_id" style="font-size: 11pt; color: #555;">
                                    <span t-field="doc.department_id.name"/>
                                </div>
                            </div>
                        </div>

                        <!-- Pie de página -->
                        <div style="margin-top: 60px; text-align: center; font-size: 10pt; color: #555; border-top: 2px solid #ccc; padding-top: 15px;">
                            <div style="font-weight: 500;">Payment Voucher</div>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
