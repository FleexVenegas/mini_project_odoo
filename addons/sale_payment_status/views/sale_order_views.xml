<odoo>

    <!-- LIST VIEW -->
    <record id="view_order_tree_payment_status" model="ir.ui.view">
        <field name="name">sale.order.tree.payment.status</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_quotation_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//tree" position="inside">
                <field name="payment_status_manual" widget="badge" decoration-success="payment_status_manual == 'paid'" decoration-warning="payment_status_manual == 'pending'" decoration-danger="payment_status_manual == 'not_paid'" groups="sale_payment_status.group_payment_status_manager"/>
            </xpath>
        </field>
    </record>

    <!-- FORM VIEW -->

    <record id="view_order_form_payment_status" model="ir.ui.view">
        <field name="name">sale.order.form.payment.status</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">

            <!-- Payment Status field (always editable, visible only to Payment Status Manager group) -->
            <xpath expr="//field[@name='payment_term_id']" position="after">
                <field name="payment_status_manual" groups="sale_payment_status.group_payment_status_manager"/>
            </xpath>

        </field>
    </record>

</odoo>