<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- VISTA TREE -->
    <record id="view_incentive_sales_run_line_tree" model="ir.ui.view">
        <field name="name">incentive.sales.run.line.tree</field>
        <field name="model">incentive.sales.run.line</field>
        <field name="arch" type="xml">
            <tree>
                <field name="currency_id" column_invisible="1"/>
                <field name="run_id"/>
                <field name="pricelist_id"/>
                <field name="amount_untaxed" sum="Total"/>
                <field name="commission_rate" sum="Average" column_invisible="1"/>
                <field name="commission_amount" sum="Total"/>
            </tree>
        </field>
    </record>


    <!-- ACTION -->
    <record id="action_incentive_sales_run_line" model="ir.actions.act_window">
        <field name="name">Incentive Sales Run Lines</field>
        <field name="res_model">incentive.sales.run.line</field>
        <field name="view_mode">tree</field>
        <field name="domain">[('run_id', '=', active_id)]</field>
        <field name="context">{'default_run_id': active_id}</field>

    </record>

</odoo>
