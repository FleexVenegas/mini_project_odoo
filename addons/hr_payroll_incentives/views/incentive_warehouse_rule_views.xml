<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <!-- VIEW TREE -->
    <record id="view_incentive_warehouse_rule_tree" model="ir.ui.view">
        <field name="name">incentive.warehouse.rule.tree</field>
        <field name="model">incentive.warehouse.rule</field>
        <field name="arch" type="xml">
            <tree string="Reglas de Incentivo de Almacén">
                <field name="name"/>
                <field name="assorted_pieces"/>
                <field name="assortment_errors"/>
                <field name="individual_punctuality"/>
                <field name="absenteeism"/>
                <field name="cleanliness_order"/>
            </tree>
        </field>
    </record>



    <!-- VIEW FORM -->
    <record id="view_incentive_warehouse_rule_form" model="ir.ui.view">
        <field name="name">incentive.warehouse.rule.form</field>
        <field name="model">incentive.warehouse.rule</field>
        <field name="arch" type="xml">
            <form string="Regla de Incentivo de Almacén">

                <sheet>

                    <!-- Título -->
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Nombre de la Regla"/>
                        </h1>
                    </div>

                    <!-- Configuración -->
                    <group string="Configuración de Incentivos">
                        <group>
                            <field name="assorted_pieces"/>
                            <field name="assortment_errors"/>
                        </group>

                        <group>
                            <field name="individual_punctuality"/>
                            <field name="absenteeism"/>
                            <field name="cleanliness_order"/>
                        </group>
                    </group>

                </sheet>

            </form>
        </field>
    </record>


    <!-- VIEW KANBAN -->
    <record id="view_incentive_warehouse_rule_kanban" model="ir.ui.view">
        <field name="name">incentive.warehouse.rule.kanban</field>
        <field name="model">incentive.warehouse.rule</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_small_column">
                <field name="name"/>
                <field name="assorted_pieces"/>
                <field name="assortment_errors"/>
                <field name="individual_punctuality"/>
                <field name="absenteeism"/>
                <field name="cleanliness_order"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click o_kanban_card">
                            <!-- Header -->
                            <div class="o_kanban_record_top">
                                <div class="o_kanban_record_headings">
                                    <strong class="o_kanban_record_title font-weight-bold font-size-lg">
                                        <field name="name"/>
                                    </strong>
                                </div>
                            </div>

                            <hr class="mt4 mb8"/>

                            <!-- Body: grid de métricas 2x3 -->
                            <div class="o_kanban_record_body">
                                <div class="row g-2">
                                    <div class="col-6">
                                        <div class="d-flex align-items-center">
                                            <i class="fa fa-cubes text-muted me-2" title="Piezas Surtidas"/>
                                            <div>
                                                <div class="text-muted" style="font-size: 11px;">Piezas Surtidas</div>
                                                <strong>
                                                    <field name="assorted_pieces"/>
                                                </strong>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-6">
                                        <div class="d-flex align-items-center">
                                            <i class="fa fa-exclamation-triangle text-warning me-2" title="Errores de Surtido"/>
                                            <div>
                                                <div class="text-muted" style="font-size: 11px;">Errores de Surtido</div>
                                                <strong>
                                                    <field name="assortment_errors"/>
                                                </strong>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-6 mt-2">
                                        <div class="d-flex align-items-center">
                                            <i class="fa fa-clock-o text-info me-2" title="Puntualidad"/>
                                            <div>
                                                <div class="text-muted" style="font-size: 11px;">Puntualidad</div>
                                                <strong>
                                                    <field name="individual_punctuality"/>
                                                </strong>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-6 mt-2">
                                        <div class="d-flex align-items-center">
                                            <i class="fa fa-user-times text-danger me-2" title="Ausentismo"/>
                                            <div>
                                                <div class="text-muted" style="font-size: 11px;">Ausentismo</div>
                                                <strong>
                                                    <field name="absenteeism"/>
                                                </strong>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-6 mt-2">
                                        <div class="d-flex align-items-center">
                                            <i class="fa fa-check-square-o text-success me-2" title="Limpieza / Orden"/>
                                            <div>
                                                <div class="text-muted" style="font-size: 11px;">Limpieza / Orden</div>
                                                <strong>
                                                    <field name="cleanliness_order"/>
                                                </strong>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ACTION -->
    <record id="action_incentive_warehouse_rule" model="ir.actions.act_window">
        <field name="name">Reglas de Incentivo de Almacén</field>
        <field name="res_model">incentive.warehouse.rule</field>
        <field name="view_mode">kanban,tree,form</field>
        <field name="view_id" ref="view_incentive_warehouse_rule_kanban"/>
    </record>
</odoo>