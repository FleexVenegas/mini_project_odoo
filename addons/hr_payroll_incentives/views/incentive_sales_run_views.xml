<?xml version="1.0" encoding="utf-8"?>
<odoo>


    <!-- View Tree -->
    <record id="view_incentive_sales_run_tree" model="ir.ui.view">
        <field name="name">incentive.sales.run.tree</field>
        <field name="model">incentive.sales.run</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="team_id"/>
                <field name="date_from"/>
                <field name="date_to"/>
                <field name="state"/>
                <field name="company_id"/>
            </tree>
        </field>
    </record>

    <!-- View Kanban -->
    <record id="view_incentive_sales_run_kanban" model="ir.ui.view">
        <field name="name">incentive.sales.run.kanban</field>
        <field name="model">incentive.sales.run</field>
        <field name="arch" type="xml">
            <kanban>
                <field name="name"/>
                <field name="team_id"/>
                <field name="date_from"/>
                <field name="date_to"/>
                <field name="state"/>
                <field name="generated_at"/>

                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click p-3">

                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <strong class="fs-5">
                                    <field name="name"/>
                                </strong>
                                <!-- <field name="state" widget="badge" decoration-muted="state == 'draft'" decoration-info="state == 'pending'" decoration-success="state == 'completed'"/> -->
                                <span t-attf-class="text-uppercase small fw-bold #{record.state.raw_value == 'draft' ? 'text-muted' : record.state.raw_value == 'pending' ? 'text-warning' : 'text-success'}">
                                    <i t-attf-class="fa #{record.state.raw_value == 'draft' ? 'fa-pencil' : record.state.raw_value == 'pending' ? 'fa-clock-o' : 'fa-check-circle'} me-1"/>
                                    <t t-esc="record.state.value"/>
                                </span>

                            </div>

                            <div class="d-flex align-items-center text-muted small mb-1">
                                <i class="fa fa-users me-1"/>
                                <field name="team_id"/>
                            </div>

                            <div class="d-flex align-items-center text-muted small mb-1">
                                <i class="fa fa-calendar me-1"/>
                                <field name="date_from"/>
&#160;–&#160;<field name="date_to"/>
                            </div>

                            <div t-if="record.generated_at.raw_value" class="d-flex align-items-center text-muted small mb-2">
                                <i class="fa fa-clock-o me-1"/>
                                <field name="generated_at"/>
                            </div>

                            <hr class="my-2" t-if="record.state.raw_value == 'completed'"/>

                            <div t-if="record.state.raw_value == 'completed'" class="d-flex justify-content-between">
                                <span class="me-2 fw-bold text-muted">Comisión:</span>
                                <field name="currency_id" invisible="1"/>

                                <field class="fw-bold text-muted" name="total_commission_amount" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                            </div>

                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>


    <!-- View Form -->
    <record id="view_incentive_sales_run_form" model="ir.ui.view">
        <field name="name">incentive.sales.run.form</field>
        <field name="model">incentive.sales.run</field>
        <field name="arch" type="xml">
            <form string="Corrida de Comisiones">
                <header>
                    <button name="compute_commissions" string="Generar comisiones" type="object" class="btn-primary" invisible="state == 'completed'" confirm="Esto recalculará y reemplazará todas las líneas de comisión existentes para esta corrida. ¿Deseas continuar?"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,pending,completed"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="e.g. COM-MOSTRADOR-2026-05" readonly="state == 'completed'"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <group string="Configuración">
                                <!-- <field name="team_id" readonly="state == 'completed'"/> -->
                                <field name="rule_ids" widget="many2many_tags" options="{'no_create': True}"/>
                                <field name="team_id" readonly="1"/>
                                <field name="company_id" groups="base.group_multi_company" readonly="state == 'completed'"/>
                            </group>
                            <group string="Periodo">
                                <field name="date_from" readonly="state == 'completed'"/>
                                <field name="date_to" readonly="state == 'completed'"/>
                                <field name="generated_at" readonly="1" invisible="not generated_at"/>
                            </group>
                        </group>
                        <group>
                            <field name="total_commission_amount" widget="monetary" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Líneas de comisión" name="commission_lines">
                            <field name="line_ids" readonly="1">
                                <tree decoration-success="commission_amount > 0">
                                    <field name="currency_id" column_invisible="1"/>
                                    <field name="rule_id"/>
                                    <field name="pricelist_id" optional="show"/>
                                    <field name="user_id" optional="show"/>

                                    <field name="amount_untaxed" sum="Total" />
                                    <!-- <field name="amount_untaxed" /> -->
                                    <field name="commission_rate"/>
                                    <field name="commission_amount" sum="Total comisión"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_incentive_sales_run" model="ir.actions.act_window">
        <field name="name">Incentivos de Ventas</field>
        <field name="res_model">incentive.sales.run</field>
        <field name="view_mode">kanban,tree,form</field>
    </record>


</odoo>
