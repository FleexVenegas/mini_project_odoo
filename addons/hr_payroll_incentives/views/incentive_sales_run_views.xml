<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_incentive_sales_run_tree" model="ir.ui.view">
        <field name="name">incentive.sales.run.tree</field>
        <field name="model">incentive.sales.run</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="team_id"/>
                <field name="date_from"/>
                <field name="date_to"/>
                <field name="state"/>
            </tree>
        </field>
    </record>

    <record id="view_incentive_sales_run_form" model="ir.ui.view">
        <field name="name">incentive.sales.run.form</field>
        <field name="model">incentive.sales.run</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="compute_commissions" string="Generar comisiones" type="object" class="btn-secondary"/>
                </header>
                <sheet>
                    <group>
                        <field name="name" placeholder="e.g. COM-MOSTRADOR-2026-05"/>
                        <field name="team_id"/>
                        <field name="date_from"/>
                        <field name="date_to"/>
                        <field name="state"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_incentive_sales_run" model="ir.actions.act_window">
        <field name="name">Sales Incentive Runs</field>
        <field name="res_model">incentive.sales.run</field>
        <field name="view_mode">tree,form</field>
    </record>


</odoo>
