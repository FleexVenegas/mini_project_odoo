<odoo>

    <!-- Acción primero (evita ParseError) -->
    <record id="action_excel_data_enrichment" model="ir.actions.act_window">
        <field name="name">ExcelDataEnrichment</field>
        <field name="res_model">excel.data.enrichment</field>
        <field name="view_mode">tree,form</field>
    </record>

    <!-- Vista Tree -->
    <record id="view_excel_data_enrichment_tree" model="ir.ui.view">
        <field name="name">excel_data_enrichment.tree</field>
        <field name="model">excel.data.enrichment</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="excel_filename"/>
                <field name="state"/>
            </tree>
        </field>
    </record>


    <!-- Vista Form -->

    <record id="view_excel_data_enrichment_form" model="ir.ui.view">
        <field name="name">excel_data_enrichment.form</field>
        <field name="model">excel.data.enrichment</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <h1>
                        <field name="name"/>
                    </h1>
                    <group string="Paso 1: Selecciona el archivo">
                        <field name="excel_file" filename="excel_filename"/>
                        <field name="excel_filename" invisible="1" force_save="1"/>
                        <field name="excel_filename" string="Nombre del archivo" readonly="1" invisible="not id or not excel_filename"/>
                        <label for="excel_file" string="Debe existir una columna que identifique el producto (SKU o código)." class="text-muted"/>
                    </group>
                    <group string="Paso 2: Configura el proceso" invisible="not excel_file">
                        <group>
                            <field name="process_type"/>
                            <field name="apply_pricelist_price"/>
                            <field name="pricelist_id" options="{'no_create': True}" invisible="not apply_pricelist_price" required="apply_pricelist_price"/>
                            <field name="add_price_column" invisible="not apply_pricelist_price"/>
                            <field name="multiply_price" invisible="not apply_pricelist_price"/>
                            <field name="multiplier_column" invisible="not (apply_pricelist_price and multiply_price)" placeholder="Ejemplo: cantidad"/>
                            <field name="multiplier_value" invisible="not (apply_pricelist_price and multiply_price)"/>
                        </group>
                        <group>
                            <field name="state" readonly="1"/>
                        </group>
                    </group>
                    <notebook invisible="not excel_file">
                        <page string="Vista previa">
                            <group>
                                <!-- <field name="detected_columns" readonly="1" nolabel="1"/> -->
                                <button name="action_refresh_preview" type="object" string="Actualizar vista previa" class="btn-link"/>
                            </group>
                            <field name="preview_html" widget="html" readonly="1" nolabel="1"/>
                        </page>
                    </notebook>
                </sheet>
                <!-- <footer>
                    <button string="Continuar" type="object" class="btn-primary"/>
                    <button string="Cancelar" special="cancel" class="btn-secondary"/>
                </footer> -->

            </form>
        </field>
    </record>

    <!-- Menú raíz -->
    <menuitem id="excel_data_enrichment_menu_root" name="ExcelDataEnrichment"/>

    <!-- Submenú -->
    <menuitem id="excel_data_enrichment_menu_modelo" name="Registros" parent="excel_data_enrichment_menu_root" action="action_excel_data_enrichment" />

</odoo>
