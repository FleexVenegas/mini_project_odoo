<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Vista de formulario para configuración de Costo Ponderado -->
        <record id="res_config_settings_view_form" model="ir.ui.view">
            <field name="name">res.config.settings.view.form.inherit.weighted.cost</field>
            <field name="model">res.config.settings</field>
            <field name="priority" eval="200"/>
            <field name="inherit_id" ref="base.res_config_settings_view_form"/>
            <field name="arch" type="xml">
                <xpath expr="//form" position="inside">
                    <app string="Costo Ponderado" name="weighted_cost_module" groups="base.group_system">
                        <block title="Configuración de Costo Ponderado">
                            <setting id="weighted_cost_enabled_setting" help="Activa el sistema de costo ponderado para productos">
                                <field name="weighted_cost_enabled"/>
                                <div class="content-group" invisible="not weighted_cost_enabled">
                                    <div class="row mt16">
                                        <label string="Cálculo Automático" for="weighted_cost_auto_calculate" class="col-lg-3 o_light_label"/>
                                        <field name="weighted_cost_auto_calculate"/>
                                    </div>
                                    <div class="row mt16">
                                        <label string="Precisión Decimal" for="weighted_cost_decimal_precision" class="col-lg-3 o_light_label"/>
                                        <field name="weighted_cost_decimal_precision"/>
                                    </div>
                                </div>
                            </setting>
                        </block>
                    </app>
                </xpath>
            </field>
        </record>

        <!-- Acción para abrir la configuración -->
        <record id="action_weighted_cost_config" model="ir.actions.act_window">
            <field name="name">Configuración de Costo Ponderado</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">res.config.settings</field>
            <field name="view_mode">form</field>
            <field name="target">inline</field>
            <field name="context">{'module': 'weighted_cost_module'}</field>
        </record>

        <!-- Menú en Ajustes -->
        <menuitem id="menu_weighted_cost_config" name="" parent="base.menu_administration" action="action_weighted_cost_config" sequence="100" groups="base.group_system"/>
    </data>
</odoo>
