<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Wizard form view -->
        <record id="view_create_product_form" model="ir.ui.view">
            <field name="name">product.creation.wizard.form</field>
            <field name="model">product.creation.wizard</field>
            <field name="arch" type="xml">
                <form string="Create Product">
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="name" placeholder="Enter product name..." required="1"/>
                            </h1>
                        </div>

                        <group>
                            <group string="Basic Information">
                                <field name="designer" placeholder="e.g: Chanel, Dior, Gucci..."/>
                                <field name="default_code" readonly="1"/>
                                <field name="barcode" placeholder="EAN/ISBN/UPC code..."/>
                                <field name="country_id" options="{'no_create': True, 'no_open': True}"/>
                            </group>

                            <group string="Classification">
                                <field name="gender"/>
                                <field name="classification"/>
                                <field name="ml"/>
                                <field name="category_product"/>
                                <field name="uom_id" options="{'no_create': True, 'no_open': True}"/>
                            </group>
                        </group>

                        <notebook>
                            <page string="Description" name="description">
                                <field name="description_product" placeholder="Enter a detailed product description..." widget="text"/>
                            </page>
                        </notebook>
                    </sheet>
                    <footer>
                        <button name="action_create_product" type="object" string="Create Product" class="btn-primary"/>
                        <button string="Cancel" special="cancel" class="btn-secondary"/>
                    </footer>
                </form>
            </field>
        </record>

        <!-- Action to open the wizard -->
        <record id="action_create_product_view" model="ir.actions.act_window">
            <field name="name">Create Product</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">product.creation.wizard</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
        </record>

        <!-- Main menu -->
        <menuitem id="menu_create_product_root" name="Create Product" parent="stock.menu_stock_inventory_control" action="action_create_product_view" sequence="1"/>
    </data>
</odoo>